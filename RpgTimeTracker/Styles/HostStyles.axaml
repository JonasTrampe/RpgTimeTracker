<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Host-app-only styles: values that deliberately deviate from the shared chrome
         (RpgTimeTracker.Shared/Styles/AppStyles.axaml), or classes only used in this app. -->

    <Style Selector="TextBlock">
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style Selector="Border.windowframe">
        <Setter Property="Background" Value="#15000000" />
        <Setter Property="BoxShadow" Value="0 24 48 0 #AA000000" />
        <Setter Property="Padding" Value="10" />
    </Style>

    <Style Selector="Border.cornerMark">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="34" />
        <Setter Property="BorderBrush" Value="{DynamicResource CornerOrnamentBrush}" />
        <Setter Property="BorderThickness" Value="3" />
        <Setter Property="Opacity" Value="0.82" />
    </Style>

    <Style Selector="Border.dataChip">
        <Setter Property="Background" Value="{DynamicResource TextInputHeaderBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource InnerFrameBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="Height" Value="30" />
    </Style>

    <Style Selector="Border.chrome">
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="Height" Value="96" />
    </Style>

    <Style Selector="Border.card">
        <Setter Property="BoxShadow" Value="0 18 36 0 #99000000" />
    </Style>

    <Style Selector="Border.addArea">
        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,14,12" />
    </Style>

    <Style Selector="Border.item">
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style Selector="Border.item.completed">
        <Setter Property="Background" Value="{DynamicResource CompletedBrush}" />
    </Style>

    <Style Selector="Border.item.pulse">
        <Setter Property="Background" Value="{DynamicResource PulseBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PulseBorderBrush}" />
    </Style>

    <Style Selector="Border.item.blink">
        <Setter Property="Opacity" Value="0.62" />
        <Setter Property="BorderBrush" Value="{DynamicResource PulseBorderBrush}" />
    </Style>

    <Style Selector="Border.sectionheader">
        <Setter Property="Margin" Value="-2 0 0 0" />
    </Style>

    <Style Selector="TextBlock.clockValue">
        <Setter Property="Width" Value="252" />
    </Style>

    <Style Selector="TextBlock.clockValue.large">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Width" Value="300" />
    </Style>

    <Style Selector="TextBlock.statusValue">
        <Setter Property="Width" Value="170" />
    </Style>

    <Style Selector="TextBlock.timeInline">
        <Setter Property="Width" Value="130" />
    </Style>

    <Style Selector="Button.startButton">
        <Setter Property="Height" Value="46" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Padding" Value="14,8" />
    </Style>

    <Style Selector="ProgressBar.timerbar">
        <Setter Property="Height" Value="10" />
        <Setter Property="CornerRadius" Value="5" />
    </Style>

    <Style Selector="TabControl.subtabs">
        <Setter Property="Padding" Value="0,2,0,0" />
    </Style>

    <Style Selector="TabControl.subtabs TabItem">
        <Setter Property="Height" Value="30" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="12,4" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Margin" Value="0,0,6,0" />
    </Style>

    <Style Selector="TabControl.subtabs TabItem:selected">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonTextBrush}" />
    </Style>

    <!-- A thematically-grouped card in the Settings tab (Appearance/Audio/Heads-up/Network/
         Protocol) - each group gets a visible frame this way instead of just a gray subheading
         in one long list. -->
    <Style Selector="Border.settingsGroup">
        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource InnerFrameBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource CardCornerRadius}" />
        <Setter Property="Padding" Value="14" />
    </Style>

    <Style Selector="TextBlock.settingsGroupTitle">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style Selector="Button.calendarToggle">
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="MinWidth" Value="96" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="Button.calendarDay">
        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource InnerFrameBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="Button.calendarDay.outside">
        <Setter Property="Opacity" Value="0.45" />
    </Style>

    <Style Selector="Button.calendarDay.today">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="Button.calendarDay.selected">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonTextBrush}" />
    </Style>

    <Style Selector="Button.calendarDay.hasEntries">
        <Setter Property="FontWeight" Value="Bold" />
    </Style>
</Styles>
