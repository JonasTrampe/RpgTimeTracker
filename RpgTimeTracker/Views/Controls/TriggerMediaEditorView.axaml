<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shared="using:RpgTimeTracker.Shared.Models"
             x:Class="RpgTimeTracker.Views.Controls.TriggerMediaEditorView"
             x:DataType="shared:TriggerMediaConfig"
             x:Name="Root">

    <Border Classes="panel">
        <StackPanel Spacing="6">
            <TextBlock Classes="muted"
                       Text="{Binding #Root.Description}"
                       TextWrapping="Wrap" />
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                <Button Grid.Column="0"
                        Content="{DynamicResource MainWindow.TriggerMedia.ChooseFromLibrary}"
                        Click="OnChooseFromLibraryClick"
                        ToolTip.Tip="{DynamicResource MainWindow.TriggerMedia.ChooseTooltip}" />
                <TextBlock Grid.Column="2"
                           Classes="muted"
                           Text="{Binding FileName}"
                           VerticalAlignment="Center"
                           Margin="8,0"
                           TextTrimming="CharacterEllipsis" />
                <Button Grid.Column="3"
                        Classes="iconsquare"
                        Content="&#10005;"
                        Command="{Binding ClearCommand}"
                        IsVisible="{Binding HasMedia}"
                        ToolTip.Tip="{DynamicResource MainWindow.TriggerMedia.ClearTooltip}" />
            </Grid>
            <StackPanel Orientation="Horizontal"
                        Spacing="12"
                        IsVisible="{Binding HasMedia}">
                <CheckBox Content="{DynamicResource MainWindow.TriggerMedia.FullscreenCheckbox}"
                          IsChecked="{Binding Fullscreen}" />
                <CheckBox Content="{DynamicResource MainWindow.TriggerMedia.PauseClockCheckbox}"
                          IsChecked="{Binding PauseClockDuringVideo}"
                          IsVisible="{Binding IsVideo}" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>