<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RpgTimeTracker.ViewModels"
             x:Class="RpgTimeTracker.Views.Controls.MapEditCanvasControl">
    <DockPanel>
        <!-- Left sidebar (floor + tool selector + tool-specific config + zoom) - a single
             ToolCombo replaces what used to be a row of separate toggle buttons (Reveal/Ping/
             Draw), and each tool's own config panel is only shown while that tool is selected
             (see OnToolChanged), so the sidebar only ever shows controls relevant to what's
             currently active. -->
        <Border DockPanel.Dock="Left" Width="210" Padding="12" BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource InnerFrameBrush}">
            <StackPanel Spacing="12">
                <ComboBox Name="FloorSelector" HorizontalAlignment="Stretch"
                          SelectionChanged="OnFloorSelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:MapFloorItemViewModel">
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <StackPanel Spacing="4">
                    <TextBlock Text="{DynamicResource MapEditor.ToolLabel}" FontWeight="SemiBold" />
                    <ComboBox Name="ToolCombo" HorizontalAlignment="Stretch" SelectedIndex="0"
                              SelectionChanged="OnToolChanged">
                        <ComboBoxItem Content="{DynamicResource MapEditor.Tool.RevealFog}" />
                        <ComboBoxItem Content="{DynamicResource MapEditor.Tool.HideFog}" />
                        <ComboBoxItem Content="{DynamicResource MapEditor.Tool.Ping}"
                                      ToolTip.Tip="{DynamicResource MapEditor.PingToolTooltip}" />
                        <ComboBoxItem Content="{DynamicResource MapEditor.Tool.Draw}"
                                      ToolTip.Tip="{DynamicResource MapEditor.DrawToolTooltip}" />
                        <ComboBoxItem Content="{DynamicResource MapEditor.Tool.Erase}" />
                    </ComboBox>
                </StackPanel>

                <!-- Reveal/Hide config - brush size only matters while painting fog. -->
                <StackPanel Name="BrushConfigPanel" Spacing="4">
                    <TextBlock Text="{DynamicResource MapEditor.BrushSizeLabel}" />
                    <Slider Name="BrushSizeSlider" Minimum="0" Maximum="40" Value="4"
                            HorizontalAlignment="Stretch" TickFrequency="1" IsSnapToTickEnabled="True" />
                </StackPanel>

                <!-- Draw config - durability tier for the next stroke. -->
                <StackPanel Name="DrawConfigPanel" Spacing="4" IsVisible="False">
                    <TextBlock Text="{DynamicResource MapEditor.LineDurabilityLabel}" />
                    <ComboBox Name="LineDurabilityCombo" HorizontalAlignment="Stretch" SelectedIndex="0">
                        <ComboBoxItem Content="{DynamicResource MapEditor.LineDurability.Temporary}" />
                        <ComboBoxItem Content="{DynamicResource MapEditor.LineDurability.SemiPermanent}" />
                        <ComboBoxItem Content="{DynamicResource MapEditor.LineDurability.Permanent}" />
                    </ComboBox>
                </StackPanel>

                <!-- Erase config - only "erase all" for now (per-line/partial erase is a later milestone). -->
                <StackPanel Name="EraseConfigPanel" Spacing="4" IsVisible="False">
                    <Button Name="EraseAllLinesButton" HorizontalAlignment="Stretch"
                            Content="{DynamicResource MapEditor.EraseAllLinesButton}"
                            Click="OnEraseAllLinesClick"
                            ToolTip.Tip="{DynamicResource MapEditor.EraseAllLinesTooltip}" />
                </StackPanel>

                <Separator />

                <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <Button Classes="iconsquare" Content="&#8722;" Width="24" Height="24" FontSize="14"
                                Click="OnZoomOutClick" ToolTip.Tip="{DynamicResource MapEditor.ZoomOutTooltip}" />
                        <TextBlock Name="ZoomLabel" VerticalAlignment="Center" Width="42" TextAlignment="Center" />
                        <Button Classes="iconsquare" Content="&#43;" Width="24" Height="24" FontSize="14"
                                Click="OnZoomInClick" ToolTip.Tip="{DynamicResource MapEditor.ZoomInTooltip}" />
                    </StackPanel>
                    <Button Content="{DynamicResource MapEditor.ZoomFitButton}" HorizontalAlignment="Stretch"
                            Click="OnZoomFitClick" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Explicit Left/Top content alignment - without it, once EditorCanvas (a fixed-size
             Panel, sized to imageSize * zoom) is smaller than the viewport on an axis (zoomed
             out/fit on a narrow map), the ScrollViewer's default Stretch alignment centers it
             there instead of anchoring it at (0,0). ApplyZoom/PanToPoint/RaiseViewportChanged all
             assume Offset=(0,0) means the panel's own origin sits at the viewport's top-left
             corner - once it's centered instead, that assumption silently breaks and every
             mirrored viewport (MapLiveWindow's preview) drifts by half the unused space. -->
        <ScrollViewer Name="ScrollHost" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      HorizontalContentAlignment="Left" VerticalContentAlignment="Top">
            <Panel Name="EditorCanvas"
                   Background="Transparent"
                   PointerPressed="OnCanvasPointerPressed"
                   PointerMoved="OnCanvasPointerMoved"
                   PointerReleased="OnCanvasPointerReleased"
                   PointerExited="OnCanvasPointerExited"
                   PointerWheelChanged="OnCanvasPointerWheelChanged">
                <Image Name="FloorImageControl" Stretch="Uniform" />
                <Image Name="FogOverlayControl" Stretch="Uniform" RenderOptions.BitmapInterpolationMode="None" />
                <Canvas Name="TokenLayer" Background="Transparent" />
                <!-- Player annotation strokes render here, above tokens - see ShowAnnotationStroke. -->
                <Canvas Name="AnnotationLayer" Background="Transparent" IsHitTestVisible="False" />
                <Ellipse Name="BrushCursor"
                         IsHitTestVisible="False"
                         IsVisible="False"
                         Stroke="{DynamicResource AccentBrush}"
                         StrokeThickness="2"
                         Fill="Transparent"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Top" />
            </Panel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
