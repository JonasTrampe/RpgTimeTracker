<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RpgTimeTracker.Views.Controls.DateTimeInput">
    <Border Background="{DynamicResource InputBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="6,4">
        <Grid ColumnDefinitions="76,8,54,8,54,14,58,8,58,8,58" RowDefinitions="auto,*">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Jahr" Classes="muted" FontSize="10"
                       HorizontalAlignment="Center" />
            <TextBox Grid.Row="1" Grid.Column="0" Name="YearBox" HorizontalContentAlignment="Center"
                     VerticalContentAlignment="Center" PlaceholderText="2080" BorderThickness="0" Padding="4,2" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="-" VerticalAlignment="Center" HorizontalAlignment="Center"
                       Margin="0,0,0,5" />
            <TextBlock Grid.Row="0" Grid.Column="2" Text="Mon" Classes="muted" FontSize="10"
                       HorizontalAlignment="Center" />
            <TextBox Grid.Row="1" Grid.Column="2" Name="MonthBox" HorizontalContentAlignment="Center"
                     VerticalContentAlignment="Center" PlaceholderText="03" BorderThickness="0" Padding="4,2" />
            <TextBlock Grid.Row="1" Grid.Column="3" Text="-" VerticalAlignment="Center" HorizontalAlignment="Center"
                       Margin="0,0,0,5" />
            <TextBlock Grid.Row="0" Grid.Column="4" Text="Tag" Classes="muted" FontSize="10"
                       HorizontalAlignment="Center" />
            <TextBox Grid.Row="1" Grid.Column="4" Name="DayBox" HorizontalContentAlignment="Center"
                     VerticalContentAlignment="Center" PlaceholderText="15" BorderThickness="0" Padding="4,2" />
            <TextBlock Grid.Row="1" Grid.Column="5" Text=" " />
            <TextBlock Grid.Row="0" Grid.Column="6" Text="Std" Classes="muted" FontSize="10"
                       HorizontalAlignment="Center" />
            <TextBox Grid.Row="1" Grid.Column="6" Name="HourBox" HorizontalContentAlignment="Center"
                     VerticalContentAlignment="Center" PlaceholderText="16" BorderThickness="0" Padding="4,2" />
            <TextBlock Grid.Row="1" Grid.Column="7" Text=":" VerticalAlignment="Center" HorizontalAlignment="Center"
                       Margin="0,0,0,5" />
            <TextBlock Grid.Row="0" Grid.Column="8" Text="Min" Classes="muted" FontSize="10"
                       HorizontalAlignment="Center" />
            <TextBox Grid.Row="1" Grid.Column="8" Name="MinuteBox" HorizontalContentAlignment="Center"
                     VerticalContentAlignment="Center" PlaceholderText="00" BorderThickness="0" Padding="4,2" />
            <TextBlock Grid.Row="1" Grid.Column="9" Text=":" VerticalAlignment="Center" HorizontalAlignment="Center"
                       Margin="0,0,0,5" />
            <TextBlock Grid.Row="0" Grid.Column="10" Text="Sek" Classes="muted" FontSize="10"
                       HorizontalAlignment="Center" />
            <TextBox Grid.Row="1" Grid.Column="10" Name="SecondBox" HorizontalContentAlignment="Center"
                     VerticalContentAlignment="Center" PlaceholderText="00" BorderThickness="0" Padding="4,2" />
        </Grid>
    </Border>
</UserControl>