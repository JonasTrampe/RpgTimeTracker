<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RpgTimeTracker.Views.Controls.LibraryAddRow"
             x:Name="Root"
             x:CompileBindings="False">

    <Grid ColumnDefinitions="*,Auto">
        <ComboBox Grid.Column="0"
                  ItemsSource="{Binding #Root.ItemsSource}"
                  SelectedItem="{Binding #Root.SelectedItem, Mode=TwoWay}"
                  PlaceholderText="{Binding #Root.PlaceholderText}"
                  HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <Button Grid.Column="1"
                Content="{DynamicResource MainWindow.Common.AddButton}"
                Command="{Binding #Root.AddCommand}"
                Margin="4,0,0,0" />
    </Grid>
</UserControl>