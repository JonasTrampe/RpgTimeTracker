<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RpgTimeTracker.Views.Controls.TimeSpanInput">
    <Border Background="{DynamicResource InputBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="6,4">
        <Grid ColumnDefinitions="58,8,58,8,58,8,58" RowDefinitions="auto,*">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Days" Classes="muted" FontSize="10"
                       HorizontalAlignment="Center" />
            <TextBox Grid.Row="1" Grid.Column="0" Name="DaysBox" HorizontalContentAlignment="Center"
                     VerticalContentAlignment="Center" PlaceholderText="0" BorderThickness="0" Padding="4,2" />
            <TextBlock Grid.Row="0" Grid.Column="2" Text="Std" Classes="muted" FontSize="10"
                       HorizontalAlignment="Center" />
            <TextBox Grid.Row="1" Grid.Column="2" Name="HoursBox" HorizontalContentAlignment="Center"
                     VerticalContentAlignment="Center" PlaceholderText="0" BorderThickness="0" Padding="4,2" />
            <TextBlock Grid.Row="1" Grid.Column="3" Text=":" VerticalAlignment="Center" HorizontalAlignment="Center"
                       Margin="0,0,0,5" />
            <TextBlock Grid.Row="0" Grid.Column="4" Text="Min" Classes="muted" FontSize="10"
                       HorizontalAlignment="Center" />
            <TextBox Grid.Row="1" Grid.Column="4" Name="MinutesBox" HorizontalContentAlignment="Center"
                     VerticalContentAlignment="Center" PlaceholderText="00" BorderThickness="0" Padding="4,2" />
            <TextBlock Grid.Row="1" Grid.Column="5" Text=":" VerticalAlignment="Center" HorizontalAlignment="Center"
                       Margin="0,0,0,5" />
            <TextBlock Grid.Row="0" Grid.Column="6" Text="Sek" Classes="muted" FontSize="10"
                       HorizontalAlignment="Center" />
            <TextBox Grid.Row="1" Grid.Column="6" Name="SecondsBox" HorizontalContentAlignment="Center"
                     VerticalContentAlignment="Center" PlaceholderText="00" BorderThickness="0" Padding="4,2" />
        </Grid>
    </Border>
</UserControl>