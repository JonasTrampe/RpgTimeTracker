<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:RpgTimeTracker.Views.Controls"
        xmlns:sharedViews="using:RpgTimeTracker.Shared.Views"
        x:Class="RpgTimeTracker.Views.MapLiveWindow"
        Title="Map"
        Width="1220" Height="700"
        MinWidth="700" MinHeight="400"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.Styles>
        <StyleInclude Source="avares://RpgTimeTracker.Shared/Styles/AppStyles.axaml" />
    </Window.Styles>

    <DockPanel Margin="10">
        <!-- WrapPanel so this row wraps instead of overflowing on a narrow window - see
             MapEditCanvasControl's toolbar for the same pattern. -->
        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,10" VerticalAlignment="Center">
            <Button Content="{DynamicResource MapLiveWindow.ResetToPreparedButton}" Margin="0,0,10,6"
                    Click="OnResetClick" />

            <ToggleButton Name="OpenToPlayersToggle" Margin="0,0,0,6"
                          Content="{DynamicResource MapEditor.OpenToPlayersButton}"
                          Click="OnToggleOpenClick" />
        </WrapPanel>

        <Grid ColumnDefinitions="*,320">
            <controls:MapEditCanvasControl x:Name="EditCanvas" Grid.Column="0" />

            <Border Grid.Column="1" Classes="settingsGroup" Margin="10,0,0,0">
                <Grid RowDefinitions="Auto,Auto,Auto,*">
                    <TextBlock Grid.Row="0" Classes="settingsGroupTitle"
                               Text="{DynamicResource MapEditor.PreviewTitle}" Margin="0,0,0,8" />
                    <sharedViews:MapDisplayView Grid.Row="1" x:Name="PreviewDisplay" />
                    <Separator Grid.Row="2" Background="{DynamicResource BorderBrush}" Margin="0,10" />
                    <controls:MapTokenPanelView Grid.Row="3" x:Name="TokenPanel" />
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>