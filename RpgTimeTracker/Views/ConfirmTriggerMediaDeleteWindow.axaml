<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RpgTimeTracker.Views.ConfirmTriggerMediaDeleteWindow"
        Title="{DynamicResource ConfirmTriggerMediaDelete.WindowTitle}"
        Width="460" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Styles>
        <StyleInclude Source="avares://RpgTimeTracker.Shared/Styles/AppStyles.axaml" />
    </Window.Styles>

    <Border Classes="card" Padding="20">
        <StackPanel Spacing="16">
            <TextBlock Classes="h2" Text="{DynamicResource ConfirmTriggerMediaDelete.Header}" />
            <TextBlock Name="UsageText" TextWrapping="Wrap" />
            <TextBlock TextWrapping="Wrap" Classes="muted"
                       Text="{DynamicResource ConfirmTriggerMediaDelete.Description}" />
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                <Button Content="{DynamicResource ConfirmTriggerMediaDelete.CancelButton}" Click="OnCancelClick" />
                <Button Content="{DynamicResource ConfirmTriggerMediaDelete.KeepButton}" Click="OnKeepClick" />
                <Button Classes="primary" Content="{DynamicResource ConfirmTriggerMediaDelete.RemoveAndDeleteButton}"
                        Click="OnRemoveAndDeleteClick" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>