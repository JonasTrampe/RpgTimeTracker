<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RpgTimeTracker.ViewModels"
        xmlns:controls="using:RpgTimeTracker.Views.Controls"
        xmlns:conv="using:RpgTimeTracker.Views.Converters"
        xmlns:viewModels="clr-namespace:RpgTimeTracker.Shared.ViewModels;assembly=RpgTimeTracker.Shared"
        x:Class="RpgTimeTracker.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{DynamicResource MainWindow.WindowTitle}"
        Width="1150" Height="740" MinWidth="900" MinHeight="600"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Styles>
        <StyleInclude Source="avares://RpgTimeTracker.Shared/Styles/AppStyles.axaml" />

        <!-- Nur Werte, die hier bewusst vom gemeinsamen Chrome abweichen bzw. Klassen,
             die ausschließlich in dieser App verwendet werden. -->
        <Style Selector="TextBlock">
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style Selector="Border.windowframe">
            <Setter Property="Background" Value="#15000000" />
            <Setter Property="BoxShadow" Value="0 24 48 0 #AA000000" />
            <Setter Property="Padding" Value="10" />
        </Style>

        <Style Selector="Border.cornerMark">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="BorderBrush" Value="{DynamicResource CornerOrnamentBrush}" />
            <Setter Property="BorderThickness" Value="3" />
            <Setter Property="Opacity" Value="0.82" />
        </Style>

        <Style Selector="Border.dataChip">
            <Setter Property="Background" Value="{DynamicResource TextInputHeaderBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InnerFrameBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Height" Value="30" />
        </Style>

        <Style Selector="Border.chrome">
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Height" Value="96" />
        </Style>

        <Style Selector="Border.card">
            <Setter Property="BoxShadow" Value="0 18 36 0 #99000000" />
        </Style>

        <Style Selector="Border.addArea">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,14,12" />
        </Style>

        <Style Selector="Border.item">
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style Selector="Border.item.completed">
            <Setter Property="Background" Value="{DynamicResource CompletedBrush}" />
        </Style>

        <Style Selector="Border.item.pulse">
            <Setter Property="Background" Value="{DynamicResource PulseBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PulseBorderBrush}" />
        </Style>

        <Style Selector="Border.item.blink">
            <Setter Property="Opacity" Value="0.62" />
            <Setter Property="BorderBrush" Value="{DynamicResource PulseBorderBrush}" />
        </Style>

        <Style Selector="Border.sectionheader">
            <Setter Property="Margin" Value="-2 0 0 0" />
        </Style>

        <Style Selector="TextBlock.clockValue">
            <Setter Property="Width" Value="252" />
        </Style>

        <Style Selector="TextBlock.clockValue.large">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Width" Value="300" />
        </Style>

        <Style Selector="TextBlock.statusValue">
            <Setter Property="Width" Value="170" />
        </Style>

        <Style Selector="TextBlock.timeInline">
            <Setter Property="Width" Value="130" />
        </Style>

        <Style Selector="Button.startButton">
            <Setter Property="Height" Value="46" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="14,8" />
        </Style>

        <Style Selector="ProgressBar.timerbar">
            <Setter Property="Height" Value="10" />
            <Setter Property="CornerRadius" Value="5" />
        </Style>

        <Style Selector="TabControl.subtabs">
            <Setter Property="Padding" Value="0,2,0,0" />
        </Style>

        <Style Selector="TabControl.subtabs TabItem">
            <Setter Property="Height" Value="30" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style Selector="TabControl.subtabs TabItem:selected">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonTextBrush}" />
        </Style>

        <!-- Eine thematisch abgegrenzte Karte im "Einstellungen"-Tab (Darstellung/Audio/
             Vorwarnung/Netzwerk/Protokoll) - jede Gruppe bekommt so einen sichtbaren Rahmen
             statt nur einer grauen Zwischenüberschrift in einer langen Liste. -->
        <Style Selector="Border.settingsGroup">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InnerFrameBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource CardCornerRadius}" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style Selector="TextBlock.settingsGroupTitle">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style Selector="Button.calendarToggle">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="Button.calendarDay">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InnerFrameBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style Selector="Button.calendarDay.outside">
            <Setter Property="Opacity" Value="0.45" />
        </Style>

        <Style Selector="Button.calendarDay.today">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>

        <Style Selector="Button.calendarDay.selected">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonTextBrush}" />
        </Style>

        <Style Selector="Button.calendarDay.hasEntries">
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
    </Window.Styles>

    <Panel>
        <Rectangle Fill="{DynamicResource WindowBackgroundImageBrush}" />
        <Rectangle Fill="{DynamicResource WindowOverlayBrush}" />
        <Rectangle Fill="{DynamicResource WindowOverlayImageBrush}" Opacity="0.16" />

        <Border Classes="windowframe" Margin="10">
            <Panel>
                <Border Classes="cornerMark" HorizontalAlignment="Left" VerticalAlignment="Top"
                        BorderThickness="3,3,0,0" />
                <Border Classes="cornerMark" HorizontalAlignment="Right" VerticalAlignment="Top"
                        BorderThickness="0,3,3,0" />
                <Border Classes="cornerMark" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                        BorderThickness="3,0,0,3" />
                <Border Classes="cornerMark" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        BorderThickness="0,0,3,3" />

                <Grid RowDefinitions="Auto,Auto,*,Auto">
                    <Border Classes="chrome" Grid.Row="0" Margin="0,0,0,14">
                        <Grid ColumnDefinitions="Auto,*">
                            <StackPanel Spacing="3" Width="610">
                                <TextBlock Classes="heroTitle" Text="{DynamicResource ThemeDisplayName}" />
                                <TextBlock Classes="muted" Text="{DynamicResource ThemeDisplaySubtitle}" />
                                <WrapPanel Height="26">
                                    <Border Classes="dataChip" Margin="0,0,6,0">
                                        <TextBlock Classes="muted" Text="RUNNING CLOCK" />
                                    </Border>
                                    <Border Classes="dataChip" Margin="0,0,6,0">
                                        <TextBlock Classes="muted" Text="TIMERS" />
                                    </Border>
                                    <Border Classes="dataChip">
                                        <TextBlock Classes="muted" Text="ALARMS" />
                                    </Border>
                                </WrapPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"
                                        VerticalAlignment="Center" HorizontalAlignment="Right" Height="52">
                                <Border Classes="dataChip" Width="280" Height="60">
                                    <StackPanel Spacing="1">
                                        <TextBlock Classes="muted"
                                                   Text="{DynamicResource MainWindow.Header.ActiveGameTime}" />
                                        <TextBlock Classes="clockValue"
                                                   Text="{Binding CurrentGameTimeText, Mode=TwoWay}" />
                                    </StackPanel>
                                </Border>
                                <Border Classes="dataChip" Width="180" Height="60">
                                    <StackPanel Spacing="1">
                                        <TextBlock Classes="muted" Text="{DynamicResource MainWindow.Header.Status}" />
                                        <TextBlock Classes="statusValue" Text="{Binding ClockStatusText, Mode=TwoWay}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="1" Spacing="8" Margin="0,0,0,14">
                        <Border
                            IsVisible="{Binding HeadsUpMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Background="{DynamicResource PulseBrush}"
                            BorderBrush="{DynamicResource PulseBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,8">
                            <TextBlock Text="{Binding HeadsUpMessage}" FontWeight="Bold" HorizontalAlignment="Center" />
                        </Border>
                    </StackPanel>

                    <Grid Grid.Row="2" ColumnDefinitions="400,*">
                        <Border Classes="card" Grid.Column="0" Margin="0,0,0,0">
                            <DockPanel LastChildFill="True">
                                <Border Classes="sectionheader" DockPanel.Dock="Top">
                                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                                        <TextBlock Classes="h1" Text="{DynamicResource MainWindow.Clock.SectionTitle}" />
                                        <Button Grid.Column="1" Classes="iconsquare" Content="&#128101;"
                                                ToolTip.Tip="{DynamicResource MainWindow.Clock.OpenPlayerWindowTooltip}"
                                                Click="OnOpenPlayerWindowClick"
                                                Margin="0,0,4,0" />
                                        <Button Grid.Column="2" Classes="iconsquare" Content="&#128190;"
                                                ToolTip.Tip="{DynamicResource MainWindow.Clock.SaveTooltip}"
                                                Click="OnSaveClick" Margin="0,0,4,0" />
                                        <Button Grid.Column="3" Classes="iconsquare" Content="&#128194;"
                                                ToolTip.Tip="{DynamicResource MainWindow.Clock.LoadTooltip}"
                                                Click="OnLoadClick" Margin="0,0,4,0" />
                                        <Button Grid.Column="4" Classes="iconsquare" Content="&#8505;"
                                                ToolTip.Tip="{DynamicResource MainWindow.Clock.AboutTooltip}"
                                                Click="OnOpenAboutClick" />
                                    </Grid>
                                </Border>

                                <ScrollViewer HorizontalScrollBarVisibility="Disabled" AllowAutoHide="false"
                                              VerticalScrollBarVisibility="Visible" Margin="12,8,12,0">
                                    <StackPanel Spacing="16" Margin="4,14,13,16">
                                        <Border Background="{DynamicResource TextInputHeaderBrush}"
                                                BorderBrush="{DynamicResource InnerFrameBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="12">
                                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                <TextBlock Classes="muted"
                                                           Text="{DynamicResource MainWindow.Clock.CurrentGameTime}" />
                                                <TextBlock Classes="clockValue large"
                                                           Text="{Binding CurrentGameTimeText, Mode=TwoWay}"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Border>

                                        <Button Classes="primary startButton"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center"
                                                Command="{Binding ToggleClockCommand}"
                                                Content="{Binding ToggleClockLabel}" />
                                        <TextBlock Classes="statusValue"
                                                   Text="{Binding ClockStatusText, Mode=TwoWay}"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   Opacity="0.8" />

                                        <Separator Background="{DynamicResource BorderBrush}" />

                                        <StackPanel Spacing="8">
                                            <TextBlock Classes="h2"
                                                       Text="{DynamicResource MainWindow.Clock.SpeedHeader}" />

                                            <NumericUpDown
                                                Value="{Binding SpeedMultiplierInput}"
                                                Minimum="0.1"
                                                Maximum="100"
                                                Increment="0.1"
                                                FormatString="0.0"
                                                NumberFormat="{DynamicResource App.NumberFormat}"
                                                HorizontalAlignment="Center" Width="300"
                                                HorizontalContentAlignment="Center"
                                                Margin="0,0,8,0" />

                                            <TextBlock Text="{DynamicResource MainWindow.Clock.SpeedDescription}"
                                                       Classes="muted" />
                                        </StackPanel>

                                        <Separator Background="{DynamicResource BorderBrush}" />

                                        <StackPanel Spacing="8">
                                            <TextBlock Classes="h2"
                                                       Text="{DynamicResource MainWindow.Clock.SetDateTimeHeader}" />
                                            <controls:DateTimeInput Text="{Binding ManualDateTimeText, Mode=TwoWay}" />
                                            <Button Content="{DynamicResource MainWindow.Clock.ApplyButton}"
                                                    Command="{Binding ApplyManualDateTimeCommand}"
                                                    HorizontalAlignment="Center" />
                                        </StackPanel>

                                        <Separator Background="{DynamicResource BorderBrush}" />

                                        <StackPanel Spacing="8">
                                            <TextBlock Classes="h2"
                                                       Text="{DynamicResource MainWindow.Clock.JumpHeader}" />
                                            <controls:TimeSpanInput Text="{Binding JumpAmountText, Mode=TwoWay}"
                                                                    HorizontalAlignment="Center" />
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                                        Spacing="4">
                                                <Button
                                                    Classes="primary"
                                                    Content="{DynamicResource MainWindow.Clock.JumpForward}"
                                                    Command="{Binding JumpForwardCommand}"
                                                    HorizontalAlignment="Stretch" Width="165" />
                                                <Button
                                                    Classes="primary"
                                                    Content="{DynamicResource MainWindow.Clock.JumpBackward}"
                                                    Command="{Binding JumpBackwardCommand}"
                                                    HorizontalAlignment="Stretch" Width="165" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                                        Spacing="4">
                                                <Button Content="{DynamicResource MainWindow.Clock.UndoJump}"
                                                        Command="{Binding UndoJumpCommand}"
                                                        IsEnabled="{Binding CanUndoJump}"
                                                        HorizontalAlignment="Stretch" Width="165"
                                                        ToolTip.Tip="{DynamicResource MainWindow.Clock.UndoJumpTooltip}" />
                                                <Button Content="{DynamicResource MainWindow.Clock.RedoJump}"
                                                        Command="{Binding RedoJumpCommand}"
                                                        IsEnabled="{Binding CanRedoJump}"
                                                        HorizontalAlignment="Stretch" Width="165"
                                                        ToolTip.Tip="{DynamicResource MainWindow.Clock.RedoJumpTooltip}" />
                                            </StackPanel>
                                            <Grid ColumnDefinitions="175,175">
                                                <WrapPanel Grid.Column="0">
                                                    <Button
                                                        Content="{DynamicResource MainWindow.Clock.QuickJumpMinus1Hour}"
                                                        Command="{Binding QuickJumpCommand}"
                                                        CommandParameter="-01:00:00" Margin="0,0,4,4" Width="83" />
                                                    <Button
                                                        Content="{DynamicResource MainWindow.Clock.QuickJumpMinus2Hours}"
                                                        Command="{Binding QuickJumpCommand}"
                                                        CommandParameter="-02:00:00" Margin="0,0,4,4" Width="83" />
                                                    <Button
                                                        Content="{DynamicResource MainWindow.Clock.QuickJumpMinus1Day}"
                                                        Command="{Binding QuickJumpCommand}"
                                                        CommandParameter="-1.00:00:00" Margin="0,0,4,4" Width="83" />
                                                    <Button
                                                        Content="{DynamicResource MainWindow.Clock.QuickJumpMinus8Hours}"
                                                        Command="{Binding QuickJumpCommand}"
                                                        CommandParameter="-08:00:00" Margin="0,0,4,4" Width="83" />
                                                </WrapPanel>
                                                <WrapPanel Grid.Column="1">
                                                    <Button
                                                        Content="{DynamicResource MainWindow.Clock.QuickJumpPlus2Hours}"
                                                        Command="{Binding QuickJumpCommand}"
                                                        CommandParameter="02:00:00" Margin="0,0,4,4" Width="83" />
                                                    <Button
                                                        Content="{DynamicResource MainWindow.Clock.QuickJumpPlus1Hour}"
                                                        Command="{Binding QuickJumpCommand}"
                                                        CommandParameter="01:00:00" Margin="0,0,4,4" Width="83" />
                                                    <Button
                                                        Content="{DynamicResource MainWindow.Clock.QuickJumpPlus8Hours}"
                                                        Command="{Binding QuickJumpCommand}"
                                                        CommandParameter="08:00:00" Margin="0,0,4,4" Width="83" />
                                                    <Button
                                                        Content="{DynamicResource MainWindow.Clock.QuickJumpPlus1Day}"
                                                        Command="{Binding QuickJumpCommand}"
                                                        CommandParameter="1.00:00:00" Margin="0,0,4,4" Width="83" />
                                                </WrapPanel>
                                            </Grid>
                                        </StackPanel>

                                        <Separator Background="{DynamicResource BorderBrush}" />

                                        <StackPanel Spacing="8">
                                            <TextBlock Classes="h2"
                                                       Text="{DynamicResource MainWindow.Clock.MarkersHeader}" />
                                            <TextBlock Classes="muted"
                                                       Text="{DynamicResource MainWindow.Clock.MarkersDescription}"
                                                       TextWrapping="Wrap" />

                                            <ItemsControl ItemsSource="{Binding JumpMarkers}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:JumpMarkerItemViewModel">
                                                        <Border Classes="item">
                                                            <StackPanel Spacing="8">
                                                                <Grid ColumnDefinitions="*,Auto">
                                                                    <TextBox Grid.Column="0"
                                                                             Text="{Binding Name, Mode=TwoWay}"
                                                                             Margin="0,0,8,0" />
                                                                    <Button Grid.Column="1" Classes="iconsquare"
                                                                            Content="&#10005;"
                                                                            Command="{Binding DeleteCommand}" />
                                                                </Grid>
                                                                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                                                                    <TextBox Grid.Column="0"
                                                                             Text="{Binding TimeOfDayText, Mode=TwoWay}"
                                                                             Width="64" PlaceholderText="hh:mm" />
                                                                    <Button Grid.Column="2" Classes="iconsquare"
                                                                            Content="&#10003;"
                                                                            ToolTip.Tip="{DynamicResource MainWindow.Clock.MarkerApplyTimeTooltip}"
                                                                            Command="{Binding ApplyTimeCommand}"
                                                                            Margin="4,0,0,0" />
                                                                    <Button Grid.Column="3" Classes="iconsquare"
                                                                            Content="&#9664;"
                                                                            ToolTip.Tip="{DynamicResource MainWindow.Clock.MarkerPreviousTooltip}"
                                                                            Command="{Binding JumpToPreviousCommand}"
                                                                            Margin="4,0,0,0" />
                                                                    <Button Grid.Column="4" Classes="iconsquare"
                                                                            Content="&#9654;"
                                                                            ToolTip.Tip="{DynamicResource MainWindow.Clock.MarkerNextTooltip}"
                                                                            Command="{Binding JumpToNextCommand}"
                                                                            Margin="4,0,0,0" />
                                                                </Grid>
                                                                <TextBlock Text="{Binding ErrorMessage}"
                                                                           Foreground="{DynamicResource WarnBrush}"
                                                                           TextWrapping="Wrap"
                                                                           IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <Grid ColumnDefinitions="*,Auto,Auto">
                                                <TextBox Grid.Column="0" Text="{Binding NewMarkerName, Mode=TwoWay}"
                                                         PlaceholderText="{DynamicResource MainWindow.Clock.MarkerNamePlaceholder}"
                                                         Margin="0,0,6,0" />
                                                <TextBox Grid.Column="1" Text="{Binding NewMarkerTime, Mode=TwoWay}"
                                                         PlaceholderText="hh:mm" Width="64" Margin="0,0,6,0" />
                                                <Button Grid.Column="2" Classes="primary"
                                                        Content="{DynamicResource MainWindow.Clock.MarkerAddButton}"
                                                        Command="{Binding AddMarkerCommand}" />
                                            </Grid>
                                        </StackPanel>

                                        <TextBlock Text="{Binding ClockErrorMessage, Mode=TwoWay}"
                                                   Foreground="{DynamicResource WarnBrush}"
                                                   TextWrapping="Wrap"
                                                   IsVisible="{Binding ClockErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                    </StackPanel>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>

                        <Border Classes="card" Grid.Column="1">
                            <DockPanel LastChildFill="True">
                                <Border Classes="sectionheader" DockPanel.Dock="Top">
                                    <TextBlock Classes="h2" Text="{DynamicResource MainWindow.ItemsMedia.SectionTitle}" />
                                </Border>

                                <TabControl Padding="12,8,12,0">
                                    <TabItem Header="{DynamicResource MainWindow.Tabs.CreateItem}">
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Visible" AllowAutoHide="false">
                                            <TabControl Classes="subtabs" Padding="12">
                                                <TabItem Header="{DynamicResource MainWindow.CreateItem.TimerTab}">
                                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,8,0,0">
                                                        <controls:NewItemBasicsEditor Grid.Row="0"
                                                                DataContext="{Binding NewTimerBasics}"
                                                                Margin="0,0,0,10" />

                                                        <Border Grid.Row="1"
                                                                Background="{DynamicResource TextInputHeaderBrush}"
                                                                BorderBrush="{DynamicResource InnerFrameBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="6"
                                                                Padding="10"
                                                                Margin="0,0,0,10">
                                                            <Grid ColumnDefinitions="90,Auto,*">
                                                                <TextBlock Grid.Column="0" Classes="muted"
                                                                           Text="{DynamicResource MainWindow.Common.Duration}"
                                                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                                                <controls:TimeSpanInput Grid.Column="1"
                                                                        Text="{Binding NewTimerDuration, Mode=TwoWay}"
                                                                        LimitDays="120"
                                                                        LimitHours="23" LimitMinutes="59"
                                                                        LimitSeconds="59" />
                                                            </Grid>
                                                        </Border>

                                                        <Border Grid.Row="2"
                                                                Background="{DynamicResource TextInputHeaderBrush}"
                                                                BorderBrush="{DynamicResource InnerFrameBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="6"
                                                                Padding="10"
                                                                Margin="0,0,0,10">
                                                            <StackPanel Spacing="6">
                                                                <TextBlock Classes="muted"
                                                                           Text="{DynamicResource MainWindow.TriggerMedia.TimerDescription}"
                                                                           TextWrapping="Wrap" />
                                                                <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                                                                    <Button Grid.Column="0"
                                                                            Content="{DynamicResource MainWindow.TriggerMedia.ChooseFromLibrary}"
                                                                            Click="OnChooseTimerTriggerMediaClick"
                                                                            ToolTip.Tip="{DynamicResource MainWindow.TriggerMedia.ChooseTooltip}" />
                                                                    <TextBlock Grid.Column="2" Classes="muted"
                                                                               Text="{Binding NewTimerTriggerMedia.FileName}"
                                                                               VerticalAlignment="Center" Margin="8,0"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <Button Grid.Column="3" Classes="iconsquare"
                                                                            Content="&#10005;"
                                                                            Command="{Binding NewTimerTriggerMedia.ClearCommand}"
                                                                            IsVisible="{Binding NewTimerTriggerMedia.HasMedia}"
                                                                            ToolTip.Tip="{DynamicResource MainWindow.TriggerMedia.ClearTooltip}" />
                                                                </Grid>
                                                                <StackPanel Orientation="Horizontal" Spacing="12"
                                                                            IsVisible="{Binding NewTimerTriggerMedia.HasMedia}">
                                                                    <CheckBox
                                                                        Content="{DynamicResource MainWindow.TriggerMedia.FullscreenCheckbox}"
                                                                        IsChecked="{Binding NewTimerTriggerMedia.Fullscreen}" />
                                                                    <CheckBox
                                                                        Content="{DynamicResource MainWindow.TriggerMedia.PauseClockCheckbox}"
                                                                        IsChecked="{Binding NewTimerTriggerMedia.PauseClockDuringVideo}"
                                                                        IsVisible="{Binding NewTimerTriggerMedia.IsVideo}" />
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>

                                                        <Button Grid.Row="3" Classes="primary"
                                                                Content="{DynamicResource MainWindow.CreateItem.AddTimerButton}"
                                                                Command="{Binding AddTimerCommand}"
                                                                HorizontalAlignment="Right" />
                                                    </Grid>
                                                </TabItem>

                                                <TabItem Header="{DynamicResource MainWindow.CreateItem.AlarmTab}">
                                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,8,0,0">
                                                        <controls:NewItemBasicsEditor Grid.Row="0"
                                                                DataContext="{Binding NewAlarmBasics}"
                                                                Margin="0,0,0,10" />

                                                        <Border Grid.Row="1"
                                                                Background="{DynamicResource TextInputHeaderBrush}"
                                                                BorderBrush="{DynamicResource InnerFrameBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="6"
                                                                Padding="10"
                                                                Margin="0,0,0,10">
                                                            <Grid RowDefinitions="Auto,Auto">
                                                                <Grid Grid.Row="0" ColumnDefinitions="90,260,*"
                                                                      Margin="0,0,0,8">
                                                                    <TextBlock Grid.Column="0" Classes="muted"
                                                                               Text="{DynamicResource MainWindow.Common.TargetTime}"
                                                                               VerticalAlignment="Center"
                                                                               Margin="0,0,10,0" />
                                                                    <StackPanel Grid.Column="1"
                                                                            Orientation="Horizontal"
                                                                            Spacing="8">
                                                                        <controls:DateTimeInput
                                                                            Text="{Binding NewAlarmDateTime, Mode=TwoWay}" />
                                                                    </StackPanel>
                                                                </Grid>
                                                                <Grid Grid.Row="1" ColumnDefinitions="90,Auto,*">
                                                                    <TextBlock Grid.Column="0" Classes="muted"
                                                                               Text="{DynamicResource MainWindow.Common.Repeat}"
                                                                               VerticalAlignment="Center"
                                                                               Margin="0,0,10,0" />
                                                                    <controls:TimeSpanInput Grid.Column="1"
                                                                            Text="{Binding NewAlarmRepeatInterval, Mode=TwoWay}"
                                                                            AllowEmpty="True" LimitDays="120"
                                                                            LimitHours="23"
                                                                            LimitMinutes="59" LimitSeconds="59" />
                                                                    <TextBlock Grid.Column="2" Classes="muted"
                                                                               Text="{DynamicResource MainWindow.Common.OnceIfEmpty}"
                                                                               VerticalAlignment="Center"
                                                                               Margin="10,0,0,0" />
                                                                </Grid>
                                                            </Grid>
                                                        </Border>

                                                        <Border Grid.Row="2"
                                                                Background="{DynamicResource TextInputHeaderBrush}"
                                                                BorderBrush="{DynamicResource InnerFrameBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="6"
                                                                Padding="10"
                                                                Margin="0,0,0,10">
                                                            <StackPanel Spacing="6">
                                                                <TextBlock Classes="muted"
                                                                           Text="{DynamicResource MainWindow.TriggerMedia.TriggerDescription}"
                                                                           TextWrapping="Wrap" />
                                                                <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                                                                    <Button Grid.Column="0"
                                                                            Content="{DynamicResource MainWindow.TriggerMedia.ChooseFromLibrary}"
                                                                            Click="OnChooseAlarmTriggerMediaClick"
                                                                            ToolTip.Tip="{DynamicResource MainWindow.TriggerMedia.ChooseTooltip}" />
                                                                    <TextBlock Grid.Column="2" Classes="muted"
                                                                               Text="{Binding NewAlarmTriggerMedia.FileName}"
                                                                               VerticalAlignment="Center" Margin="8,0"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <Button Grid.Column="3" Classes="iconsquare"
                                                                            Content="&#10005;"
                                                                            Command="{Binding NewAlarmTriggerMedia.ClearCommand}"
                                                                            IsVisible="{Binding NewAlarmTriggerMedia.HasMedia}"
                                                                            ToolTip.Tip="{DynamicResource MainWindow.TriggerMedia.ClearTooltip}" />
                                                                </Grid>
                                                                <StackPanel Orientation="Horizontal" Spacing="12"
                                                                            IsVisible="{Binding NewAlarmTriggerMedia.HasMedia}">
                                                                    <CheckBox
                                                                        Content="{DynamicResource MainWindow.TriggerMedia.FullscreenCheckbox}"
                                                                        IsChecked="{Binding NewAlarmTriggerMedia.Fullscreen}" />
                                                                    <CheckBox
                                                                        Content="{DynamicResource MainWindow.TriggerMedia.PauseClockCheckbox}"
                                                                        IsChecked="{Binding NewAlarmTriggerMedia.PauseClockDuringVideo}"
                                                                        IsVisible="{Binding NewAlarmTriggerMedia.IsVideo}" />
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>

                                                        <Button Grid.Row="3" Classes="primary"
                                                                Content="{DynamicResource MainWindow.CreateItem.AddAlarmButton}"
                                                                Command="{Binding AddAlarmCommand}"
                                                                HorizontalAlignment="Right" />
                                                    </Grid>
                                                </TabItem>

                                                <TabItem Header="{DynamicResource MainWindow.CreateItem.IntervalTab}">
                                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,8,0,0">
                                                        <controls:NewItemBasicsEditor Grid.Row="0"
                                                                DataContext="{Binding NewIntervalBasics}"
                                                                Margin="0,0,0,10" />

                                                        <Border Grid.Row="1"
                                                                Background="{DynamicResource TextInputHeaderBrush}"
                                                                BorderBrush="{DynamicResource InnerFrameBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="6"
                                                                Padding="10"
                                                                Margin="0,0,0,10">
                                                            <Grid RowDefinitions="Auto,Auto,Auto">
                                                                <Grid Grid.Row="0"
                                                                      ColumnDefinitions="90,Auto,*"
                                                                      Margin="0,0,0,8" HorizontalAlignment="Left">
                                                                    <TextBlock Grid.Column="0" Classes="muted"
                                                                               Text="{DynamicResource MainWindow.Common.Every}"
                                                                               VerticalAlignment="Center"
                                                                               Margin="0,0,10,0" />
                                                                    <controls:TimeSpanInput Grid.Column="1"
                                                                            Text="{Binding NewIntervalInterval, Mode=TwoWay}"
                                                                            LimitDays="120"
                                                                            LimitHours="23" LimitMinutes="59"
                                                                            LimitSeconds="59" />
                                                                </Grid>
                                                                <Grid Grid.Row="1"
                                                                      ColumnDefinitions="90,Auto,*"
                                                                      Margin="0,0,0,8" HorizontalAlignment="Left">
                                                                    <TextBlock Grid.Column="0" Classes="muted"
                                                                               Text="{DynamicResource MainWindow.CreateItem.ActiveForLabel}"
                                                                               VerticalAlignment="Center"
                                                                               Margin="0,0,10,0" />
                                                                    <controls:TimeSpanInput Grid.Column="1"
                                                                            Text="{Binding NewIntervalActiveDuration, Mode=TwoWay}"
                                                                            LimitDays="120"
                                                                            LimitHours="23" LimitMinutes="59"
                                                                            LimitSeconds="59" />
                                                                </Grid>
                                                                <Grid Grid.Row="2" ColumnDefinitions="90,150,*">
                                                                    <TextBlock Grid.Column="0" Classes="muted"
                                                                               Text="{DynamicResource MainWindow.Common.Max}"
                                                                               VerticalAlignment="Center"
                                                                               Margin="0,0,10,0" />
                                                                    <TextBox Grid.Column="1"
                                                                             Text="{Binding NewIntervalMaxRepeats, Mode=TwoWay}"
                                                                             PlaceholderText="∞" />
                                                                    <TextBlock Grid.Column="2" Classes="muted"
                                                                               Text="{DynamicResource MainWindow.Common.EmptyOrZeroUnlimited}"
                                                                               VerticalAlignment="Center"
                                                                               HorizontalAlignment="Left"
                                                                               Margin="10,0,0,0" />
                                                                </Grid>
                                                            </Grid>
                                                        </Border>

                                                        <Border Grid.Row="2"
                                                                Background="{DynamicResource TextInputHeaderBrush}"
                                                                BorderBrush="{DynamicResource InnerFrameBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="6"
                                                                Padding="10"
                                                                Margin="0,0,0,10">
                                                            <StackPanel Spacing="6">
                                                                <TextBlock Classes="muted"
                                                                           Text="{DynamicResource MainWindow.TriggerMedia.IntervalDescription}"
                                                                           TextWrapping="Wrap" />
                                                                <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                                                                    <Button Grid.Column="0"
                                                                            Content="{DynamicResource MainWindow.TriggerMedia.ChooseFromLibrary}"
                                                                            Click="OnChooseIntervalTriggerMediaClick"
                                                                            ToolTip.Tip="{DynamicResource MainWindow.TriggerMedia.ChooseTooltip}" />
                                                                    <TextBlock Grid.Column="2" Classes="muted"
                                                                               Text="{Binding NewIntervalTriggerMedia.FileName}"
                                                                               VerticalAlignment="Center" Margin="8,0"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <Button Grid.Column="3" Classes="iconsquare"
                                                                            Content="&#10005;"
                                                                            Command="{Binding NewIntervalTriggerMedia.ClearCommand}"
                                                                            IsVisible="{Binding NewIntervalTriggerMedia.HasMedia}"
                                                                            ToolTip.Tip="{DynamicResource MainWindow.TriggerMedia.ClearTooltip}" />
                                                                </Grid>
                                                                <StackPanel Orientation="Horizontal" Spacing="12"
                                                                            IsVisible="{Binding NewIntervalTriggerMedia.HasMedia}">
                                                                    <CheckBox
                                                                        Content="{DynamicResource MainWindow.TriggerMedia.FullscreenCheckbox}"
                                                                        IsChecked="{Binding NewIntervalTriggerMedia.Fullscreen}" />
                                                                    <CheckBox
                                                                        Content="{DynamicResource MainWindow.TriggerMedia.PauseClockCheckbox}"
                                                                        IsChecked="{Binding NewIntervalTriggerMedia.PauseClockDuringVideo}"
                                                                        IsVisible="{Binding NewIntervalTriggerMedia.IsVideo}" />
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>

                                                        <Button Grid.Row="3" Classes="primary"
                                                                Content="{DynamicResource MainWindow.CreateItem.AddIntervalButton}"
                                                                Command="{Binding AddIntervalEventCommand}"
                                                                HorizontalAlignment="Right" />
                                                    </Grid>
                                                </TabItem>
                                            </TabControl>
                                        </ScrollViewer>
                                    </TabItem>

                                    <TabItem Header="{DynamicResource MainWindow.Tabs.ItemList}">
                                        <DockPanel LastChildFill="True">
                                            <Border Classes="sectionheader" DockPanel.Dock="Top">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Grid.Column="0" Classes="h2"
                                                               Text="{DynamicResource MainWindow.ItemList.SharedTimelineHeader}" />
                                                    <Button Grid.Column="1"
                                                            Classes="primary"
                                                            Content="{Binding NextEventJumpLabel}"
                                                            Command="{Binding JumpToNextEventCommand}"
                                                            VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>

                                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                                          AllowAutoHide="false">
                                                <ItemsControl ItemsSource="{Binding TimelineItems}"
                                                              Margin="16,14,16,16">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:TimelineDisplayItemViewModel">
                                                            <Border Classes="item"
                                                                    Classes.completed="{Binding IsCompleted}"
                                                                    Classes.pulse="{Binding IsActive}"
                                                                    Classes.blink="{Binding IsBlinkActive}">
                                                                <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                                                                      ColumnDefinitions="Auto,*,Auto">
                                                                    <Border Grid.Row="0" Grid.RowSpan="3"
                                                                            Grid.Column="0"
                                                                            Width="8" CornerRadius="4"
                                                                            Margin="0,0,10,0"
                                                                            Background="{Binding ItemBorderBrush}" />

                                                                    <StackPanel Grid.Row="0" Grid.Column="1"
                                                                            Orientation="Horizontal" Spacing="10">
                                                                        <PathIcon Data="{Binding IconGeometry}"
                                                                                Width="20" Height="20"
                                                                                Foreground="{DynamicResource TextBrush}"
                                                                                PointerPressed="OnTimelineIconPointerPressed"
                                                                                ToolTip.Tip="{DynamicResource MainWindow.Common.IconPickerTooltip}" />
                                                                        <TextBlock Text="{Binding Name}"
                                                                                FontWeight="Bold"
                                                                                VerticalAlignment="Center" />
                                                                        <Border Classes="dataChip" Height="28"
                                                                                Padding="8,3">
                                                                            <TextBlock Text="{Binding KindLabel}"
                                                                                    Classes="muted" />
                                                                        </Border>
                                                                        <TextBlock
                                                                            Text="{DynamicResource MainWindow.ItemList.SlOnlyLabel}"
                                                                            Foreground="{DynamicResource WarnBrush}"
                                                                            VerticalAlignment="Center"
                                                                            IsVisible="{Binding IsSlOnly}" />
                                                                        <TextBlock Text="{Binding StatusText}"
                                                                                Foreground="{DynamicResource OkBrush}"
                                                                                VerticalAlignment="Center" />
                                                                    </StackPanel>

                                                                    <StackPanel Grid.Row="0" Grid.Column="2"
                                                                            Orientation="Horizontal" Spacing="6">
                                                                        <Button Content="{Binding StartPauseLabel}"
                                                                                Command="{Binding ToggleRunCommand}"
                                                                                IsVisible="{Binding CanStartPause}" />
                                                                        <Button
                                                                            Content="{DynamicResource MainWindow.ItemList.ResetButton}"
                                                                            Command="{Binding ResetCommand}"
                                                                            IsVisible="{Binding CanReset}" />
                                                                        <Button
                                                                            Content="{DynamicResource MainWindow.ItemList.ConfirmButton}"
                                                                            Command="{Binding DismissCommand}"
                                                                            IsVisible="{Binding CanDismiss}" />
                                                                        <Button
                                                                            Content="{DynamicResource MainWindow.ItemList.SettingsButton}"
                                                                            Command="{Binding ToggleConfigCommand}" />
                                                                        <Button Classes="iconsquare" Content="&#10005;"
                                                                                Command="{Binding DeleteCommand}" />
                                                                    </StackPanel>

                                                                    <StackPanel Grid.Row="1" Grid.Column="1"
                                                                            Grid.ColumnSpan="2"
                                                                            Orientation="Horizontal" Spacing="12"
                                                                            Margin="0,8,0,0">
                                                                        <TextBlock Classes="timeInline"
                                                                                Text="{Binding PrimaryValue}"
                                                                                MinWidth="130" />
                                                                        <TextBlock Classes="muted"
                                                                                Text="{Binding DetailText}" />
                                                                        <TextBlock Text="{Binding ErrorMessage}"
                                                                                Foreground="{DynamicResource WarnBrush}"
                                                                                IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                                    </StackPanel>

                                                                    <Border Grid.Row="2" Grid.Column="1"
                                                                            Grid.ColumnSpan="2"
                                                                            IsVisible="{Binding IsConfigVisible}"
                                                                            Background="{DynamicResource TextInputHeaderBrush}"
                                                                            BorderBrush="{DynamicResource InnerFrameBrush}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="6"
                                                                            Padding="10"
                                                                            Margin="0,10,0,0">
                                                                        <StackPanel Spacing="12">
                                                                            <Border
                                                                                Background="{DynamicResource SurfaceBrush}"
                                                                                BorderBrush="{DynamicResource InnerFrameBrush}"
                                                                                BorderThickness="1"
                                                                                CornerRadius="6"
                                                                                Padding="10">
                                                                                <Grid
                                                                                    ColumnDefinitions="Auto,*,Auto,Auto"
                                                                                    RowDefinitions="Auto,Auto">
                                                                                    <TextBlock Grid.Row="0"
                                                                                        Grid.Column="0" Classes="muted"
                                                                                        Text="{DynamicResource MainWindow.Common.Name}"
                                                                                        VerticalAlignment="Center"
                                                                                        Margin="0,0,10,8" />
                                                                                    <TextBox Grid.Row="0"
                                                                                        Grid.Column="1"
                                                                                        Text="{Binding EditName, Mode=TwoWay}"
                                                                                        MinWidth="220"
                                                                                        Margin="0,0,12,8" />
                                                                                    <TextBlock Grid.Row="0"
                                                                                        Grid.Column="2" Classes="muted"
                                                                                        Text="{DynamicResource MainWindow.ItemList.SoundLabel}"
                                                                                        VerticalAlignment="Center"
                                                                                        Margin="0,0,10,8" />
                                                                                    <StackPanel Grid.Row="0"
                                                                                        Grid.Column="3"
                                                                                        Orientation="Horizontal"
                                                                                        Spacing="6" Margin="0,0,0,8">
                                                                                        <ComboBox
                                                                                            ItemsSource="{Binding SoundOptions}"
                                                                                            SelectedItem="{Binding EditSound, Mode=TwoWay}"
                                                                                            Width="150">
                                                                                            <ComboBox.ItemTemplate>
                                                                                                <DataTemplate>
                                                                                                    <TextBlock
                                                                                                        Text="{Binding Converter={x:Static conv:SoundDisplayNameConverter.Instance}}" />
                                                                                                </DataTemplate>
                                                                                            </ComboBox.ItemTemplate>
                                                                                        </ComboBox>
                                                                                        <NumericUpDown
                                                                                            Value="{Binding EditSoundRepeatCount, Mode=TwoWay}"
                                                                                            Minimum="0" Maximum="20"
                                                                                            FormatString="0"
                                                                                            Width="120"
                                                                                            ToolTip.Tip="{DynamicResource MainWindow.ItemList.SoundRepeatTooltip}" />
                                                                                    </StackPanel>

                                                                                    <TextBlock Grid.Row="1"
                                                                                        Grid.Column="0" Classes="muted"
                                                                                        Text="{DynamicResource MainWindow.Common.Color}"
                                                                                        VerticalAlignment="Center"
                                                                                        Margin="0,0,10,0" />
                                                                                    <ColorPicker Grid.Row="1"
                                                                                        Grid.Column="1"
                                                                                        Color="{Binding EditColorHex, Mode=TwoWay, Converter={x:Static conv:HexColorConverter.Instance}}"
                                                                                        HorizontalAlignment="Left" />
                                                                                    <StackPanel Grid.Row="1"
                                                                                        Grid.Column="2"
                                                                                        Grid.ColumnSpan="2"
                                                                                        Orientation="Horizontal"
                                                                                        Spacing="12">
                                                                                        <CheckBox
                                                                                            Content="{DynamicResource MainWindow.ItemList.BlinkCheckbox}"
                                                                                            IsChecked="{Binding EditBlink, Mode=TwoWay}"
                                                                                            VerticalAlignment="Center" />
                                                                                        <CheckBox
                                                                                            Content="{DynamicResource MainWindow.ItemList.PlayerVisibleCheckbox}"
                                                                                            IsChecked="{Binding EditIsPlayerVisible, Mode=TwoWay}"
                                                                                            VerticalAlignment="Center" />
                                                                                    </StackPanel>
                                                                                </Grid>
                                                                            </Border>

                                                                            <Border IsVisible="{Binding IsTimer}"
                                                                                    Background="{DynamicResource SurfaceBrush}"
                                                                                    BorderBrush="{DynamicResource InnerFrameBrush}"
                                                                                    BorderThickness="1"
                                                                                    CornerRadius="6" Padding="10">
                                                                                <Grid ColumnDefinitions="Auto,Auto,*">
                                                                                    <TextBlock Grid.Column="0"
                                                                                        Classes="muted"
                                                                                        Text="{DynamicResource MainWindow.Common.Duration}"
                                                                                        VerticalAlignment="Center"
                                                                                        Margin="0,0,10,0" />
                                                                                    <controls:TimeSpanInput
                                                                                        Grid.Column="1"
                                                                                        Text="{Binding DurationText, Mode=TwoWay}"
                                                                                        LimitDays="120"
                                                                                        LimitHours="23"
                                                                                        LimitMinutes="59"
                                                                                        LimitSeconds="59" />
                                                                                    <TextBlock Grid.Column="2"
                                                                                        Classes="muted"
                                                                                        Text="{DynamicResource MainWindow.ItemList.DurationUnitsHint}"
                                                                                        VerticalAlignment="Center"
                                                                                        Margin="10,0,0,0" />
                                                                                </Grid>
                                                                            </Border>

                                                                            <Border IsVisible="{Binding IsAlarm}"
                                                                                    Background="{DynamicResource SurfaceBrush}"
                                                                                    BorderBrush="{DynamicResource InnerFrameBrush}"
                                                                                    BorderThickness="1"
                                                                                    CornerRadius="6" Padding="10">
                                                                                <StackPanel Spacing="8">
                                                                                    <Grid
                                                                                        ColumnDefinitions="Auto,Auto,*">
                                                                                        <TextBlock Grid.Column="0"
                                                                                            Classes="muted"
                                                                                            Text="{DynamicResource MainWindow.Common.TargetTime}"
                                                                                            VerticalAlignment="Center"
                                                                                            Margin="0,0,10,0" />
                                                                                        <controls:DateTimeInput
                                                                                            Grid.Column="1"
                                                                                            Text="{Binding TriggerAtDateTimeText, Mode=TwoWay}"
                                                                                            MinYear="1" MaxYear="9999"
                                                                                            LimitHours="23"
                                                                                            LimitMinutes="59"
                                                                                            LimitSeconds="59" />
                                                                                        <TextBlock Grid.Column="2"
                                                                                            Classes="muted"
                                                                                            Text="{DynamicResource MainWindow.ItemList.MouseWheelHint}"
                                                                                            VerticalAlignment="Center"
                                                                                            Margin="10,0,0,0" />
                                                                                    </Grid>
                                                                                    <Grid
                                                                                        ColumnDefinitions="Auto,Auto,*">
                                                                                        <TextBlock Grid.Column="0"
                                                                                            Classes="muted"
                                                                                            Text="{DynamicResource MainWindow.Common.Repeat}"
                                                                                            VerticalAlignment="Center"
                                                                                            Margin="0,0,10,0" />
                                                                                        <controls:TimeSpanInput
                                                                                            Grid.Column="1"
                                                                                            Text="{Binding RepeatIntervalTextEdit, Mode=TwoWay}"
                                                                                            AllowEmpty="True"
                                                                                            LimitDays="120"
                                                                                            LimitHours="23"
                                                                                            LimitMinutes="59"
                                                                                            LimitSeconds="59" />
                                                                                        <TextBlock Grid.Column="2"
                                                                                            Classes="muted"
                                                                                            Text="{DynamicResource MainWindow.Common.OnceIfEmpty}"
                                                                                            VerticalAlignment="Center"
                                                                                            Margin="10,0,0,0" />
                                                                                    </Grid>
                                                                                </StackPanel>
                                                                            </Border>

                                                                            <Border IsVisible="{Binding IsInterval}"
                                                                                    Background="{DynamicResource SurfaceBrush}"
                                                                                    BorderBrush="{DynamicResource InnerFrameBrush}"
                                                                                    BorderThickness="1"
                                                                                    CornerRadius="6" Padding="10">
                                                                                <StackPanel Spacing="8">
                                                                                    <Grid
                                                                                        ColumnDefinitions="Auto,Auto,Auto,Auto,*">
                                                                                        <TextBlock Grid.Column="0"
                                                                                            Classes="muted"
                                                                                            Text="{DynamicResource MainWindow.Common.Every}"
                                                                                            VerticalAlignment="Center"
                                                                                            Margin="0,0,10,0" />
                                                                                        <controls:TimeSpanInput
                                                                                            Grid.Column="1"
                                                                                            Text="{Binding IntervalText, Mode=TwoWay}"
                                                                                            LimitDays="120"
                                                                                            LimitHours="23"
                                                                                            LimitMinutes="59"
                                                                                            LimitSeconds="59" />
                                                                                        <TextBlock Grid.Column="2"
                                                                                            Classes="muted"
                                                                                            Text="{DynamicResource MainWindow.ItemList.ActiveForLabelLower}"
                                                                                            VerticalAlignment="Center"
                                                                                            Margin="18,0,10,0" />
                                                                                        <controls:TimeSpanInput
                                                                                            Grid.Column="3"
                                                                                            Text="{Binding ActiveDurationText, Mode=TwoWay}"
                                                                                            LimitDays="120"
                                                                                            LimitHours="23"
                                                                                            LimitMinutes="59"
                                                                                            LimitSeconds="59" />
                                                                                    </Grid>
                                                                                    <Grid
                                                                                        ColumnDefinitions="Auto,100,*">
                                                                                        <TextBlock Grid.Column="0"
                                                                                            Classes="muted"
                                                                                            Text="{DynamicResource MainWindow.Common.Max}"
                                                                                            VerticalAlignment="Center"
                                                                                            Margin="0,0,10,0" />
                                                                                        <TextBox Grid.Column="1"
                                                                                            Text="{Binding MaxRepeatsText, Mode=TwoWay}"
                                                                                            PlaceholderText="∞" />
                                                                                        <TextBlock Grid.Column="2"
                                                                                            Classes="muted"
                                                                                            Text="{DynamicResource MainWindow.Common.EmptyOrZeroUnlimited}"
                                                                                            VerticalAlignment="Center"
                                                                                            Margin="10,0,0,0" />
                                                                                    </Grid>
                                                                                </StackPanel>
                                                                            </Border>

                                                                            <Border
                                                                                Background="{DynamicResource SurfaceBrush}"
                                                                                BorderBrush="{DynamicResource InnerFrameBrush}"
                                                                                BorderThickness="1" CornerRadius="6"
                                                                                Padding="10">
                                                                                <StackPanel Spacing="6">
                                                                                    <TextBlock Classes="muted"
                                                                                        Text="{DynamicResource MainWindow.TriggerMedia.TriggerDescription}"
                                                                                        TextWrapping="Wrap" />
                                                                                    <Grid
                                                                                        ColumnDefinitions="Auto,Auto,*,Auto">
                                                                                        <Button Grid.Column="0"
                                                                                            Content="{DynamicResource MainWindow.TriggerMedia.ChooseFromLibrary}"
                                                                                            Click="OnChooseItemTriggerMediaClick"
                                                                                            ToolTip.Tip="{DynamicResource MainWindow.TriggerMedia.ChooseTooltip}" />
                                                                                        <TextBlock Grid.Column="2"
                                                                                            Classes="muted"
                                                                                            Text="{Binding TriggerMedia.FileName}"
                                                                                            VerticalAlignment="Center"
                                                                                            Margin="8,0"
                                                                                            TextTrimming="CharacterEllipsis" />
                                                                                        <Button Grid.Column="3"
                                                                                            Classes="iconsquare"
                                                                                            Content="&#10005;"
                                                                                            Command="{Binding TriggerMedia.ClearCommand}"
                                                                                            IsVisible="{Binding TriggerMedia.HasMedia}"
                                                                                            ToolTip.Tip="{DynamicResource MainWindow.TriggerMedia.ClearTooltip}" />
                                                                                    </Grid>
                                                                                    <StackPanel
                                                                                        Orientation="Horizontal"
                                                                                        Spacing="12"
                                                                                        IsVisible="{Binding TriggerMedia.HasMedia}">
                                                                                        <CheckBox
                                                                                            Content="{DynamicResource MainWindow.TriggerMedia.FullscreenCheckbox}"
                                                                                            IsChecked="{Binding TriggerMedia.Fullscreen}" />
                                                                                        <CheckBox
                                                                                            Content="{DynamicResource MainWindow.TriggerMedia.PauseClockCheckbox}"
                                                                                            IsChecked="{Binding TriggerMedia.PauseClockDuringVideo}"
                                                                                            IsVisible="{Binding TriggerMedia.IsVideo}" />
                                                                                    </StackPanel>
                                                                                </StackPanel>
                                                                            </Border>

                                                                            <Button Classes="primary"
                                                                                    Content="{DynamicResource MainWindow.ItemList.ApplyChangesButton}"
                                                                                    Command="{Binding ApplyEditsCommand}"
                                                                                    HorizontalAlignment="Right"
                                                                                    MinWidth="230" />
                                                                        </StackPanel>
                                                                    </Border>

                                                                    <ProgressBar Grid.Row="3" Grid.Column="1"
                                                                            Grid.ColumnSpan="2"
                                                                            Classes="timerbar"
                                                                            IsVisible="{Binding HasProgress}"
                                                                            Minimum="0" Maximum="1"
                                                                            Value="{Binding Progress}" />
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </DockPanel>
                                    </TabItem>

                                    <TabItem Header="{DynamicResource MainWindow.Tabs.Library}">
                                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" AllowAutoHide="false"
                                                      VerticalScrollBarVisibility="Visible">
                                            <Grid ColumnDefinitions="*,*" Margin="4,14,13,16">
                                                <!-- Linke Spalte: Senden + persistente Bibliothek. -->
                                                <Border Grid.Column="0" Classes="settingsGroup" Margin="0 0 4 0">
                                                    <controls:LibraryPanelView x:Name="MediaLibraryPanel"
                                                                               Title="{DynamicResource MainWindow.Library.MediaLibraryTitle}"
                                                                               Description="{DynamicResource MainWindow.Library.MediaLibraryDescription}"
                                                                               EmptyStateText="{DynamicResource MainWindow.Library.MediaLibraryEmptyState}"
                                                                               HasNoItems="{Binding HasNoMediaLibraryItems}"
                                                                               ErrorMessage="{Binding MediaErrorMessage, Mode=TwoWay}"
                                                                               ItemsSource="{Binding MediaLibrary}">
                                                        <controls:LibraryPanelView.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:MediaLibraryItemViewModel">
                                                                <Border Classes="item" Width="120"
                                                                        Margin="0,0,10,10"
                                                                        DoubleTapped="OnMediaLibraryItemDoubleTapped"
                                                                        ToolTip.Tip="{DynamicResource MainWindow.Library.ItemTooltip}">
                                                                    <StackPanel Spacing="6">
                                                                        <Panel>
                                                                            <Border Width="96" Height="96"
                                                                                    CornerRadius="6"
                                                                                    ClipToBounds="True"
                                                                                    Background="{DynamicResource SurfaceAltBrush}"
                                                                                    HorizontalAlignment="Center">
                                                                                <Panel>
                                                                                    <Image
                                                                                        Source="{Binding Thumbnail}"
                                                                                        Stretch="UniformToFill"
                                                                                        IsVisible="{Binding HasThumbnail}" />
                                                                                    <TextBlock
                                                                                        Text="{Binding FallbackIcon}"
                                                                                        FontSize="28"
                                                                                        HorizontalAlignment="Center"
                                                                                        VerticalAlignment="Center"
                                                                                        IsVisible="{Binding !HasThumbnail}" />
                                                                                </Panel>
                                                                            </Border>
                                                                            <StackPanel Orientation="Horizontal"
                                                                                    Spacing="2"
                                                                                    HorizontalAlignment="Right"
                                                                                    VerticalAlignment="Top"
                                                                                    Margin="0,-4,-4,0">
                                                                                <Button Classes="iconsquare"
                                                                                    Content="⚙" Width="22"
                                                                                    Height="22"
                                                                                    FontSize="11"
                                                                                    ToolTip.Tip="{DynamicResource MainWindow.Library.RenameTooltip}">
                                                                                    <Button.Flyout>
                                                                                        <Flyout Placement="Bottom">
                                                                                            <StackPanel Spacing="8"
                                                                                                Width="200">
                                                                                                <TextBlock
                                                                                                    Classes="muted"
                                                                                                    Text="{DynamicResource MainWindow.Common.Name}" />
                                                                                                <TextBox
                                                                                                    Text="{Binding Name, Mode=TwoWay}" />
                                                                                            </StackPanel>
                                                                                        </Flyout>
                                                                                    </Button.Flyout>
                                                                                </Button>
                                                                                <Button Classes="iconsquare"
                                                                                    Content="&#10005;"
                                                                                    Command="{Binding DeleteCommand}"
                                                                                    ToolTip.Tip="{DynamicResource MainWindow.Common.RemoveFromLibraryTooltip}"
                                                                                    Width="22" Height="22"
                                                                                    FontSize="10" />
                                                                            </StackPanel>
                                                                        </Panel>
                                                                        <TextBlock Text="{Binding Name}"
                                                                                FontWeight="Bold" FontSize="12"
                                                                                TextTrimming="CharacterEllipsis"
                                                                                HorizontalAlignment="Center" />
                                                                        <StackPanel Orientation="Horizontal"
                                                                                Spacing="6"
                                                                                HorizontalAlignment="Center">
                                                                            <TextBlock Text="{Binding KindLabel}"
                                                                                    Classes="muted" FontSize="11"
                                                                                    VerticalAlignment="Center" />
                                                                            <CheckBox Content="🔁"
                                                                                    IsChecked="{Binding Loop}"
                                                                                    IsVisible="{Binding SupportsLoop}"
                                                                                    ToolTip.Tip="{DynamicResource MainWindow.Library.LoopTooltip}"
                                                                                    Padding="4,0" FontSize="11" />
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </controls:LibraryPanelView.ItemTemplate>
                                                    </controls:LibraryPanelView>
                                                </Border>
                                                <Border Grid.Column="1" Classes="settingsGroup">
                                                    <StackPanel Spacing="8" Margin="10,0,0,0">

                                                        <StackPanel Spacing="4" IsVisible="False">
                                                            <TextBlock Classes="muted"
                                                                       Text="{DynamicResource MainWindow.Library.SendMediaLabel}" />
                                                            <Grid ColumnDefinitions="*,Auto">
                                                                <Button Grid.Column="0"
                                                                        Content="{DynamicResource MainWindow.Library.SendMediaButton}"
                                                                        Click="OnSendMediaClick"
                                                                        HorizontalAlignment="Stretch" Margin="0,0,8,0" />
                                                                <CheckBox Grid.Column="1"
                                                                          Content="{DynamicResource MainWindow.Common.LoopCheckbox}"
                                                                          IsChecked="{Binding SendMediaLoop}"
                                                                          VerticalAlignment="Center"
                                                                          ToolTip.Tip="{DynamicResource MainWindow.Library.LoopVideoTooltip}" />
                                                            </Grid>
                                                            <TextBlock Classes="muted"
                                                                       Text="{DynamicResource MainWindow.Library.SupportedFormats}"
                                                                       TextWrapping="Wrap" />
                                                            <Separator Background="{DynamicResource BorderBrush}" />
                                                        </StackPanel>
                                                        <TextBlock Classes="h2"
                                                                   Text="{DynamicResource MainWindow.Library.GalleryHeader}" />
                                                        <TextBlock Classes="muted"
                                                                   Text="{DynamicResource MainWindow.Library.GalleryEmptyState}"
                                                                   IsVisible="{Binding HasNoSentMediaItems}" />
                                                        <ItemsControl ItemsSource="{Binding SentMediaItems}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="vm:SentMediaItemViewModel">
                                                                    <Border Classes="item" Width="120"
                                                                            Margin="0,0,10,10"
                                                                            PointerPressed="OnSentMediaItemPointerPressed"
                                                                            ToolTip.Tip="{DynamicResource MainWindow.Library.GalleryItemTooltip}">
                                                                        <StackPanel Spacing="6">
                                                                            <Panel>
                                                                                <Border Width="96" Height="96"
                                                                                    CornerRadius="6"
                                                                                    ClipToBounds="True"
                                                                                    Background="{DynamicResource SurfaceAltBrush}"
                                                                                    HorizontalAlignment="Center">
                                                                                    <Panel>
                                                                                        <Image
                                                                                            Source="{Binding Thumbnail}"
                                                                                            Stretch="UniformToFill"
                                                                                            IsVisible="{Binding HasThumbnail}" />
                                                                                        <TextBlock
                                                                                            Text="{Binding FallbackIcon}"
                                                                                            FontSize="28"
                                                                                            HorizontalAlignment="Center"
                                                                                            VerticalAlignment="Center"
                                                                                            IsVisible="{Binding !HasThumbnail}" />
                                                                                    </Panel>
                                                                                </Border>
                                                                                <StackPanel Orientation="Horizontal"
                                                                                    Spacing="2"
                                                                                    HorizontalAlignment="Right"
                                                                                    VerticalAlignment="Top"
                                                                                    Margin="0,-4,-4,0">
                                                                                    <Button Classes="iconsquare"
                                                                                        Content="&#10005;"
                                                                                        Command="{Binding RetractCommand}"
                                                                                        ToolTip.Tip="{DynamicResource MainWindow.Library.RetractTooltip}"
                                                                                        Width="22" Height="22"
                                                                                        FontSize="10" />
                                                                                </StackPanel>
                                                                            </Panel>
                                                                            <TextBlock Text="{Binding Name}"
                                                                                    FontWeight="Bold" FontSize="12"
                                                                                    TextTrimming="CharacterEllipsis"
                                                                                    HorizontalAlignment="Center" />
                                                                            <StackPanel Orientation="Horizontal"
                                                                                    Spacing="6"
                                                                                    HorizontalAlignment="Center">
                                                                                <TextBlock Text="{Binding KindLabel}"
                                                                                    Classes="muted" FontSize="11"
                                                                                    VerticalAlignment="Center" />
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </Border>

                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </ScrollViewer>
                                    </TabItem>

                                    <TabItem Header="{DynamicResource MainWindow.Tabs.Sounds}">
                                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" AllowAutoHide="false"
                                                      VerticalScrollBarVisibility="Visible">
                                            <Grid ColumnDefinitions="*,*" Margin="4,14,13,16">
                                                <Border Grid.Column="0" Classes="settingsGroup" Margin="0 0 4 0">
                                                    <controls:LibraryPanelView x:Name="SoundLibraryPanel"
                                                                               Title="{DynamicResource MainWindow.Sounds.LibraryTitle}"
                                                                               Description="{DynamicResource MainWindow.Sounds.LibraryDescription}"
                                                                               EmptyStateText="{DynamicResource MainWindow.Sounds.LibraryEmptyState}"
                                                                               HasNoItems="{Binding HasNoSoundLibraryItems}"
                                                                               ErrorMessage="{Binding MediaErrorMessage, Mode=TwoWay}"
                                                                               ItemsSource="{Binding SoundLibrary}">
                                                        <controls:LibraryPanelView.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:SoundLibraryItemViewModel">
                                                                <Border Classes="item" Width="140"
                                                                        Margin="0,0,10,10"
                                                                        PointerPressed="OnSoundLibraryItemPointerPressed"
                                                                        ToolTip.Tip="{DynamicResource MainWindow.Sounds.ItemTooltip}">
                                                                    <StackPanel Spacing="10">
                                                                        <Grid ColumnDefinitions="*,Auto,Auto">
                                                                            <PathIcon Grid.Column="0"
                                                                                    Data="{Binding IconGeometry}"
                                                                                    Width="20" Height="20"
                                                                                    HorizontalAlignment="Left"
                                                                                    Foreground="{DynamicResource TextBrush}"
                                                                                    PointerPressed="OnSoundIconPointerPressed"
                                                                                    ToolTip.Tip="{DynamicResource MainWindow.Common.IconPickerTooltip}" />
                                                                            <Button Grid.Column="1"
                                                                                    Classes="iconsquare" Content="⚙"
                                                                                    Width="22" Height="22"
                                                                                    FontSize="11"
                                                                                    ToolTip.Tip="{DynamicResource MainWindow.Sounds.SettingsTooltip}">
                                                                                <Button.Flyout>
                                                                                    <Flyout Placement="Bottom">
                                                                                        <StackPanel Spacing="8"
                                                                                            Width="240">
                                                                                            <TextBlock
                                                                                                Classes="muted"
                                                                                                Text="{DynamicResource MainWindow.Common.Name}" />
                                                                                            <TextBox
                                                                                                Text="{Binding Name, Mode=TwoWay}" />

                                                                                            <TextBlock
                                                                                                Classes="muted"
                                                                                                Text="{DynamicResource MainWindow.Common.Volume}" />
                                                                                            <Slider Minimum="0"
                                                                                                Maximum="100"
                                                                                                Value="{Binding Volume}" />

                                                                                            <CheckBox
                                                                                                Content="{DynamicResource MainWindow.Sounds.LoopCheckbox}"
                                                                                                IsChecked="{Binding Loop}" />

                                                                                            <StackPanel Spacing="2"
                                                                                                IsVisible="{Binding !Loop}">
                                                                                                <TextBlock
                                                                                                    Classes="muted"
                                                                                                    Text="{DynamicResource MainWindow.Sounds.RepeatCountLabel}" />
                                                                                                <NumericUpDown
                                                                                                    Value="{Binding RepeatCount}"
                                                                                                    Minimum="1"
                                                                                                    Maximum="20"
                                                                                                    FormatString="0"
                                                                                                    Width="120" />
                                                                                            </StackPanel>

                                                                                            <Separator
                                                                                                Background="{DynamicResource BorderBrush}" />
                                                                                            <TextBlock
                                                                                                Classes="muted"
                                                                                                Text="{DynamicResource MainWindow.Sounds.TrimHeader}"
                                                                                                TextWrapping="Wrap" />
                                                                                            <Grid
                                                                                                ColumnDefinitions="*,*"
                                                                                                ColumnSpacing="8">
                                                                                                <StackPanel
                                                                                                    Grid.Column="0"
                                                                                                    Spacing="2">
                                                                                                    <TextBlock
                                                                                                        Classes="muted"
                                                                                                        Text="{DynamicResource MainWindow.Sounds.TrimStartLabel}"
                                                                                                        FontSize="11" />
                                                                                                    <NumericUpDown
                                                                                                        Value="{Binding TrimStartSeconds}"
                                                                                                        Minimum="0"
                                                                                                        FormatString="0.0"
                                                                                                        Increment="0.5"
                                                                                                        NumberFormat="{DynamicResource App.NumberFormat}"
                                                                                                        HorizontalAlignment="Stretch" />
                                                                                                </StackPanel>
                                                                                                <StackPanel
                                                                                                    Grid.Column="1"
                                                                                                    Spacing="2">
                                                                                                    <TextBlock
                                                                                                        Classes="muted"
                                                                                                        Text="{DynamicResource MainWindow.Sounds.TrimEndLabel}"
                                                                                                        FontSize="11"
                                                                                                        ToolTip.Tip="{DynamicResource MainWindow.Sounds.TrimEndTooltip}" />
                                                                                                    <NumericUpDown
                                                                                                        Value="{Binding TrimEndSeconds}"
                                                                                                        Minimum="0"
                                                                                                        FormatString="0.0"
                                                                                                        Increment="0.5"
                                                                                                        NumberFormat="{DynamicResource App.NumberFormat}"
                                                                                                        HorizontalAlignment="Stretch" />
                                                                                                </StackPanel>
                                                                                            </Grid>

                                                                                            <Button
                                                                                                Content="{DynamicResource MainWindow.Sounds.TestButton}"
                                                                                                Command="{Binding TestCommand}"
                                                                                                HorizontalAlignment="Stretch"
                                                                                                ToolTip.Tip="{DynamicResource MainWindow.Sounds.TestTooltip}" />
                                                                                        </StackPanel>
                                                                                    </Flyout>
                                                                                </Button.Flyout>
                                                                            </Button>
                                                                            <Button Grid.Column="2"
                                                                                    Classes="iconsquare"
                                                                                    Content="&#10005;"
                                                                                    Command="{Binding DeleteCommand}"
                                                                                    ToolTip.Tip="{DynamicResource MainWindow.Common.RemoveFromLibraryTooltip}"
                                                                                    Width="22" Height="22"
                                                                                    FontSize="10" />
                                                                        </Grid>
                                                                        <TextBlock Text="{Binding Name}"
                                                                                FontWeight="Bold" FontSize="12"
                                                                                TextTrimming="CharacterEllipsis" />
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </controls:LibraryPanelView.ItemTemplate>
                                                    </controls:LibraryPanelView>
                                                </Border>
                                                <Border Grid.Column="1" Classes="settingsGroup">
                                                    <StackPanel Spacing="4">

                                                        <StackPanel IsVisible="False">
                                                            <TextBlock Classes="muted"
                                                                       Text="{DynamicResource MainWindow.Sounds.SendSoundLabel}" />
                                                            <Grid ColumnDefinitions="*,Auto">
                                                                <Button Grid.Column="0"
                                                                        Content="{DynamicResource MainWindow.Sounds.SendSoundButton}"
                                                                        Click="OnSendSoundClick"
                                                                        HorizontalAlignment="Stretch"
                                                                        Margin="0,0,8,0" />
                                                                <CheckBox Grid.Column="1"
                                                                          Content="{DynamicResource MainWindow.Common.LoopCheckbox}"
                                                                          IsChecked="{Binding SendSoundLoop}"
                                                                          VerticalAlignment="Center"
                                                                          ToolTip.Tip="{DynamicResource MainWindow.Sounds.LoopTooltip}" />
                                                            </Grid>
                                                            <TextBlock Classes="muted"
                                                                       Text="{DynamicResource MainWindow.Sounds.SupportedFormats}"
                                                                       TextWrapping="Wrap" />

                                                            <Separator Background="{DynamicResource BorderBrush}" />


                                                        </StackPanel>

                                                        <StackPanel Spacing="8" Margin="10,0,0,0">
                                                            <TextBlock
                                                                Classes="h2"
                                                                Text="{DynamicResource MainWindow.Sounds.ActivePlayingHeader}"
                                                                VerticalAlignment="Center" />
                                                            <TextBlock Classes="muted"
                                                                       Text="{DynamicResource MainWindow.Sounds.NoActiveSounds}"
                                                                       IsVisible="{Binding HasNoActivePlayingSounds}" />

                                                            <ItemsControl ItemsSource="{Binding ActivePlayingSounds}"
                                                                          IsVisible="{Binding !HasNoActivePlayingSounds}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel Orientation="Horizontal" />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:DataType="vm:ActiveSoundViewModel">
                                                                        <Border Classes="item"
                                                                                Width="160"
                                                                                Margin="0,0,10,10">
                                                                            <StackPanel Spacing="8">
                                                                                <Grid ColumnDefinitions="*,Auto">
                                                                                    <StackPanel Grid.Column="0"
                                                                                        Spacing="2">
                                                                                        <TextBlock
                                                                                            Text="{Binding Name}"
                                                                                            FontWeight="Bold"
                                                                                            FontSize="12"
                                                                                            TextTrimming="CharacterEllipsis" />
                                                                                        <TextBlock
                                                                                            Text="{DynamicResource MainWindow.Sounds.LoopLabel}"
                                                                                            Classes="muted"
                                                                                            FontSize="11"
                                                                                            IsVisible="{Binding Loop}" />
                                                                                    </StackPanel>
                                                                                    <Button Grid.Column="1"
                                                                                        Classes="iconsquare"
                                                                                        Content="⏹"
                                                                                        Command="{Binding StopCommand}"
                                                                                        ToolTip.Tip="{DynamicResource MainWindow.Sounds.StopTooltip}"
                                                                                        Width="22"
                                                                                        Height="22"
                                                                                        FontSize="10"
                                                                                        VerticalAlignment="Top" />
                                                                                </Grid>
                                                                                <StackPanel Spacing="2">
                                                                                    <TextBlock Classes="muted"
                                                                                        Text="{DynamicResource MainWindow.Common.Volume}"
                                                                                        FontSize="11" />
                                                                                    <Slider Minimum="0"
                                                                                        Maximum="100"
                                                                                        Value="{Binding Volume}"
                                                                                        ToolTip.Tip="{DynamicResource MainWindow.Sounds.VolumeLiveTooltip}" />
                                                                                </StackPanel>
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>

                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </ScrollViewer>
                                    </TabItem>

                                    <TabItem Header="{DynamicResource MainWindow.Tabs.Music}">
                                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" AllowAutoHide="false"
                                                      VerticalScrollBarVisibility="Visible">
                                            <DockPanel>
                                                <Border DockPanel.Dock="Top" Classes="settingsGroup"
                                                        Margin="4,14,13,4"
                                                        IsVisible="{Binding IsPlaylistPlaying}">
                                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,140"
                                                          ColumnSpacing="10">
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{DynamicResource MainWindow.Music.NowPlayingLabel}"
                                                                   FontWeight="Bold"
                                                                   VerticalAlignment="Center" />
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding CurrentPlaylist.Name}"
                                                                       FontWeight="Bold"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding CurrentPlaylistTrack.Name}"
                                                                       Classes="muted" FontSize="11"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                        <Button Grid.Column="2" Classes="iconsquare" Content="&#9198;"
                                                                Command="{Binding PreviousPlaylistTrackCommand}"
                                                                ToolTip.Tip="{DynamicResource MainWindow.Music.PreviousTooltip}"
                                                                Width="28" Height="28" VerticalAlignment="Center" />
                                                        <Button Grid.Column="3" Classes="iconsquare" Content="&#9199;"
                                                                Command="{Binding NextPlaylistTrackCommand}"
                                                                ToolTip.Tip="{DynamicResource MainWindow.Music.NextTooltip}"
                                                                Width="28" Height="28" VerticalAlignment="Center" />
                                                        <Button Grid.Column="4" Classes="iconsquare" Content="&#9209;"
                                                                Command="{Binding StopPlaylistCommand}"
                                                                ToolTip.Tip="{DynamicResource MainWindow.Music.StopTooltip}"
                                                                Width="28" Height="28" VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="5"
                                                                   Text="{DynamicResource MainWindow.Common.Volume}"
                                                                   Classes="muted" VerticalAlignment="Center" />
                                                        <Slider Grid.Column="6" Minimum="0" Maximum="100"
                                                                Value="{Binding CurrentPlaylistVolume}"
                                                                VerticalAlignment="Center"
                                                                ToolTip.Tip="{DynamicResource MainWindow.Music.VolumeTooltip}" />
                                                    </Grid>
                                                </Border>

                                                <Grid ColumnDefinitions="*,*" Margin="4,14,13,16">
                                                <Border Grid.Column="0" Classes="settingsGroup" Margin="0 0 4 0">
                                                    <controls:LibraryPanelView x:Name="MusicLibraryPanel"
                                                                               Title="{DynamicResource MainWindow.Music.LibraryTitle}"
                                                                               Description="{DynamicResource MainWindow.Music.LibraryDescription}"
                                                                               EmptyStateText="{DynamicResource MainWindow.Music.LibraryEmptyState}"
                                                                               HasNoItems="{Binding HasNoMusicLibraryItems}"
                                                                               ErrorMessage="{Binding MediaErrorMessage, Mode=TwoWay}"
                                                                               ItemsSource="{Binding MusicLibrary}">
                                                        <controls:LibraryPanelView.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:MusicLibraryItemViewModel">
                                                                <Border Classes="item" Width="140"
                                                                        Margin="0,0,10,10"
                                                                        PointerPressed="OnMusicLibraryItemPointerPressed"
                                                                        ToolTip.Tip="{DynamicResource MainWindow.Music.ItemTooltip}">
                                                                    <StackPanel Spacing="10">
                                                                        <Grid ColumnDefinitions="*,Auto,Auto">
                                                                            <PathIcon Grid.Column="0"
                                                                                    Data="{Binding IconGeometry}"
                                                                                    Width="20" Height="20"
                                                                                    HorizontalAlignment="Left"
                                                                                    Foreground="{DynamicResource TextBrush}"
                                                                                    PointerPressed="OnMusicIconPointerPressed"
                                                                                    ToolTip.Tip="{DynamicResource MainWindow.Common.IconPickerTooltip}" />
                                                                            <Button Grid.Column="1"
                                                                                    Classes="iconsquare" Content="⚙"
                                                                                    Width="22" Height="22"
                                                                                    FontSize="11"
                                                                                    ToolTip.Tip="{DynamicResource MainWindow.Sounds.SettingsTooltip}">
                                                                                <Button.Flyout>
                                                                                    <Flyout Placement="Bottom">
                                                                                        <StackPanel Spacing="8"
                                                                                            Width="220">
                                                                                            <TextBlock
                                                                                                Classes="muted"
                                                                                                Text="{DynamicResource MainWindow.Common.Name}" />
                                                                                            <TextBox
                                                                                                Text="{Binding Name, Mode=TwoWay}" />

                                                                                            <TextBlock
                                                                                                Classes="muted"
                                                                                                Text="{DynamicResource MainWindow.Common.Volume}" />
                                                                                            <Slider Minimum="0"
                                                                                                Maximum="100"
                                                                                                Value="{Binding Volume}" />

                                                                                            <Button
                                                                                                Content="{DynamicResource MainWindow.Sounds.TestButton}"
                                                                                                Command="{Binding TestCommand}"
                                                                                                HorizontalAlignment="Stretch"
                                                                                                ToolTip.Tip="{DynamicResource MainWindow.Sounds.TestTooltip}" />
                                                                                        </StackPanel>
                                                                                    </Flyout>
                                                                                </Button.Flyout>
                                                                            </Button>
                                                                            <Button Grid.Column="2"
                                                                                    Classes="iconsquare"
                                                                                    Content="&#10005;"
                                                                                    Command="{Binding DeleteCommand}"
                                                                                    ToolTip.Tip="{DynamicResource MainWindow.Common.RemoveFromLibraryTooltip}"
                                                                                    Width="22" Height="22"
                                                                                    FontSize="10" />
                                                                        </Grid>
                                                                        <TextBlock Text="{Binding Name}"
                                                                                FontWeight="Bold" FontSize="12"
                                                                                TextTrimming="CharacterEllipsis" />
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </controls:LibraryPanelView.ItemTemplate>
                                                    </controls:LibraryPanelView>
                                                </Border>

                                                <Border Grid.Column="1" Classes="settingsGroup">
                                                    <StackPanel Spacing="10">
                                                        <TextBlock Classes="settingsGroupTitle"
                                                                   Text="{DynamicResource MainWindow.Music.PlaylistsTitle}" />
                                                        <TextBlock Classes="muted"
                                                                   Text="{DynamicResource MainWindow.Music.PlaylistsDescription}"
                                                                   TextWrapping="Wrap" />
                                                        <Button Content="{DynamicResource MainWindow.Music.AddPlaylistButton}"
                                                                Command="{Binding AddPlaylistCommand}" />
                                                        <TextBlock Classes="muted"
                                                                   Text="{DynamicResource MainWindow.Music.PlaylistsEmptyState}"
                                                                   IsVisible="{Binding HasNoPlaylists}"
                                                                   FontStyle="Italic" />
                                                        <ListBox ItemsSource="{Binding Playlists}"
                                                                 SelectedItem="{Binding SelectedPlaylist, Mode=TwoWay}"
                                                                 IsVisible="{Binding !HasNoPlaylists}"
                                                                 MaxHeight="180">
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate x:DataType="vm:PlaylistViewModel">
                                                                    <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                                                                          Margin="0,2">
                                                                        <TextBox Grid.Column="0"
                                                                                 Text="{Binding Name, Mode=TwoWay}" />
                                                                        <TextBlock Grid.Column="1" Classes="muted"
                                                                                   Text="{Binding Tracks.Count}"
                                                                                   VerticalAlignment="Center"
                                                                                   Margin="8,0" />
                                                                        <Button Grid.Column="2"
                                                                                Classes="iconsquare"
                                                                                Content="&#9654;"
                                                                                Command="{Binding $parent[TabItem].DataContext.PlayPlaylistCommand}"
                                                                                CommandParameter="{Binding}"
                                                                                ToolTip.Tip="{DynamicResource MainWindow.Music.PlayTooltip}"
                                                                                Width="22" Height="22"
                                                                                FontSize="10" />
                                                                        <Button Grid.Column="3"
                                                                                Classes="iconsquare"
                                                                                Content="&#10005;"
                                                                                Command="{Binding DeleteCommand}"
                                                                                ToolTip.Tip="{DynamicResource MainWindow.Common.RemoveFromLibraryTooltip}"
                                                                                Width="22" Height="22"
                                                                                FontSize="10" />
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                        </ListBox>

                                                        <StackPanel Spacing="8"
                                                                    IsVisible="{Binding SelectedPlaylist, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                            <Separator Background="{DynamicResource BorderBrush}" />
                                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                                <CheckBox Grid.Column="0"
                                                                          Content="{DynamicResource MainWindow.Music.LoopPlaylistCheckbox}"
                                                                          IsChecked="{Binding SelectedPlaylist.LoopPlaylist}" />
                                                                <CheckBox Grid.Column="1"
                                                                          Content="{DynamicResource MainWindow.Music.ShuffleCheckbox}"
                                                                          IsChecked="{Binding SelectedPlaylist.Shuffle}" />
                                                            </Grid>

                                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                                <ComboBox Grid.Column="0"
                                                                          ItemsSource="{Binding MusicLibrary}"
                                                                          SelectedItem="{Binding PlaylistTrackToAdd, Mode=TwoWay}"
                                                                          DisplayMemberBinding="{Binding Name}"
                                                                          HorizontalAlignment="Stretch"
                                                                          PlaceholderText="{DynamicResource MainWindow.Music.AddTrackPlaceholder}" />
                                                                <Button Grid.Column="1"
                                                                        Content="{DynamicResource MainWindow.Music.AddTrackButton}"
                                                                        Command="{Binding AddSelectedTrackToSelectedPlaylistCommand}" />
                                                            </Grid>

                                                            <TextBlock Classes="muted"
                                                                       Text="{DynamicResource MainWindow.Music.PlaylistEmptyState}"
                                                                       IsVisible="{Binding SelectedPlaylist.HasNoTracks}"
                                                                       FontStyle="Italic" />
                                                            <ItemsControl ItemsSource="{Binding SelectedPlaylist.Tracks}"
                                                                          IsVisible="{Binding !SelectedPlaylist.HasNoTracks}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:DataType="vm:PlaylistTrackViewModel">
                                                                        <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                                                                              Margin="0,2">
                                                                            <TextBlock Grid.Column="0"
                                                                                       Text="{Binding Track.Name}"
                                                                                       VerticalAlignment="Center"
                                                                                       TextTrimming="CharacterEllipsis" />
                                                                            <Button Grid.Column="1"
                                                                                    Classes="iconsquare"
                                                                                    Content="&#8593;"
                                                                                    Command="{Binding MoveUpCommand}"
                                                                                    ToolTip.Tip="{DynamicResource MainWindow.Music.MoveUpTooltip}"
                                                                                    Width="22" Height="22"
                                                                                    FontSize="10" />
                                                                            <Button Grid.Column="2"
                                                                                    Classes="iconsquare"
                                                                                    Content="&#8595;"
                                                                                    Command="{Binding MoveDownCommand}"
                                                                                    ToolTip.Tip="{DynamicResource MainWindow.Music.MoveDownTooltip}"
                                                                                    Width="22" Height="22"
                                                                                    FontSize="10" />
                                                                            <Button Grid.Column="3"
                                                                                    Classes="iconsquare"
                                                                                    Content="&#10005;"
                                                                                    Command="{Binding RemoveCommand}"
                                                                                    ToolTip.Tip="{DynamicResource MainWindow.Music.RemoveTrackTooltip}"
                                                                                    Width="22" Height="22"
                                                                                    FontSize="10" />
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                                </Grid>
                                            </DockPanel>
                                        </ScrollViewer>
                                    </TabItem>

                                    <TabItem Header="{DynamicResource MainWindow.Tabs.Maps}">
                                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" AllowAutoHide="false"
                                                      VerticalScrollBarVisibility="Visible">
                                            <Grid ColumnDefinitions="350,*" Margin="4,14,13,16">
                                                <Border Grid.Column="0" Classes="settingsGroup" Margin="0,0,14,14">
                                                    <StackPanel Spacing="10">
                                                        <TextBlock Classes="settingsGroupTitle"
                                                                   Text="{DynamicResource MainWindow.Maps.MapsTitle}" />
                                                        <TextBlock Classes="muted"
                                                                   Text="{DynamicResource MainWindow.Maps.MapsDescription}"
                                                                   TextWrapping="Wrap" />
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <Button Content="{DynamicResource MainWindow.Maps.AddMapButton}"
                                                                    Command="{Binding AddMapCommand}" />
                                                            <Button Content="{DynamicResource MainWindow.Maps.ImportButton}"
                                                                    Click="OnImportMapClick" />
                                                        </StackPanel>
                                                        <TextBlock Classes="muted"
                                                                   Text="{DynamicResource MainWindow.Maps.EmptyState}"
                                                                   IsVisible="{Binding HasNoMaps}"
                                                                   FontStyle="Italic" />
                                                        <ListBox ItemsSource="{Binding MapLibrary}"
                                                                 SelectedItem="{Binding SelectedMap, Mode=TwoWay}"
                                                                 IsVisible="{Binding !HasNoMaps}">
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate x:DataType="vm:MapItemViewModel">
                                                                    <Grid ColumnDefinitions="*,Auto,Auto"
                                                                          Margin="0,2">
                                                                        <TextBox Grid.Column="0"
                                                                                 Text="{Binding Name, Mode=TwoWay}" />
                                                                        <TextBlock Grid.Column="1" Classes="muted"
                                                                                   Text="{Binding Floors.Count}"
                                                                                   VerticalAlignment="Center"
                                                                                   Margin="8,0" />
                                                                        <Button Grid.Column="2" Classes="iconsquare"
                                                                                Content="&#8942;" Width="36" Height="36"
                                                                                ToolTip.Tip="{DynamicResource MainWindow.Maps.MoreActionsTooltip}">
                                                                            <Button.Flyout>
                                                                                <MenuFlyout Placement="BottomEdgeAlignedRight">
                                                                                    <MenuItem Header="{DynamicResource MainWindow.Maps.ExportButton}"
                                                                                              Click="OnExportMapClick" />
                                                                                    <MenuItem Header="{DynamicResource MainWindow.Common.RemoveFromLibraryTooltip}"
                                                                                              Command="{Binding DeleteCommand}" />
                                                                                </MenuFlyout>
                                                                            </Button.Flyout>
                                                                        </Button>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                        </ListBox>
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="1" Classes="settingsGroup" Margin="0,0,14,14"
                                                        IsVisible="{Binding SelectedMap, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                    <DockPanel>
                                                        <TextBlock DockPanel.Dock="Top" Classes="settingsGroupTitle"
                                                                   Margin="0,0,0,10"
                                                                   Text="{Binding SelectedMap.Name}" />
                                                        <TextBlock DockPanel.Dock="Top" Classes="muted"
                                                                   Margin="0,0,0,10"
                                                                   Text="{DynamicResource MainWindow.Maps.NoFloorsState}"
                                                                   IsVisible="{Binding SelectedMap.HasNoFloors}"
                                                                   FontStyle="Italic" />
                                                        <!-- Docked to the bottom so the action buttons stay pinned
                                                             there regardless of how long the floor list grows,
                                                             instead of just flowing after it. -->
                                                        <!-- WrapPanel (not a horizontal StackPanel) so these wrap
                                                             onto more than one line instead of overflowing/squishing
                                                             the panel when it's resized narrower. -->
                                                        <WrapPanel DockPanel.Dock="Bottom" Margin="0,10,0,0"
                                                                   Orientation="Horizontal">
                                                            <Button Margin="0,0,6,6"
                                                                    Content="{DynamicResource MainWindow.Maps.AddFloorButton}"
                                                                    Click="OnAddMapFloorClick" />
                                                            <Button Margin="0,0,6,6"
                                                                    Content="{DynamicResource MainWindow.Maps.EditButton}"
                                                                    Click="OnEditSelectedFloorClick"
                                                                    IsEnabled="{Binding !IsSelectedMapOpenToPlayers}"
                                                                    ToolTip.Tip="{DynamicResource MainWindow.Maps.EditDisabledWhileShownTooltip}" />
                                                            <Button Margin="0,0,6,6"
                                                                    Content="{DynamicResource MainWindow.Maps.ShowButton}"
                                                                    Click="OnShowMapClick"
                                                                    IsEnabled="{Binding CanShowSelectedMap}"
                                                                    ToolTip.Tip="{DynamicResource MainWindow.Maps.ShowDisabledWhilePreparingTooltip}" />
                                                            <TextBlock Margin="0,0,6,6"
                                                                       Text="{DynamicResource MainWindow.Maps.ShownToPlayersLabel}"
                                                                       VerticalAlignment="Center"
                                                                       Classes="muted"
                                                                       IsVisible="{Binding IsSelectedMapOpenToPlayers}" />
                                                        </WrapPanel>
                                                        <!-- Floors are layers of the same map, so their order is
                                                             meaningful - sortable via the up/down buttons below,
                                                             unlike the map library list itself. -->
                                                        <ListBox ItemsSource="{Binding SelectedMap.Floors}"
                                                                 SelectedItem="{Binding EditingFloor, Mode=TwoWay}">
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate x:DataType="vm:MapFloorItemViewModel">
                                                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto"
                                                                          ColumnSpacing="4" Margin="0,2">
                                                                        <Image Grid.Column="0"
                                                                               Source="{Binding Thumbnail}"
                                                                               Width="32" Height="32"
                                                                               Stretch="UniformToFill" />
                                                                        <TextBox Grid.Column="1"
                                                                                 Text="{Binding Name, Mode=TwoWay}"
                                                                                 VerticalAlignment="Center" />
                                                                        <Button Grid.Column="2" Classes="iconsquare"
                                                                                Content="&#9650;"
                                                                                Width="22" Height="22"
                                                                                FontSize="9"
                                                                                Click="OnMoveFloorUpClick"
                                                                                ToolTip.Tip="{DynamicResource MainWindow.Maps.MoveUpTooltip}" />
                                                                        <Button Grid.Column="3" Classes="iconsquare"
                                                                                Content="&#9660;"
                                                                                Width="22" Height="22"
                                                                                FontSize="9"
                                                                                Click="OnMoveFloorDownClick"
                                                                                ToolTip.Tip="{DynamicResource MainWindow.Maps.MoveDownTooltip}" />
                                                                        <Button Grid.Column="4" Classes="iconsquare"
                                                                                Content="&#10005;"
                                                                                Width="22" Height="22"
                                                                                FontSize="10"
                                                                                Command="{Binding DeleteCommand}"
                                                                                ToolTip.Tip="{DynamicResource MainWindow.Common.RemoveFromLibraryTooltip}" />
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                        </ListBox>
                                                    </DockPanel>
                                                </Border>
                                            </Grid>
                                        </ScrollViewer>
                                    </TabItem>

                                    <TabItem Header="{DynamicResource MainWindow.Tabs.Calendar}">
                                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" AllowAutoHide="false"
                                                      VerticalScrollBarVisibility="Visible">
                                            <StackPanel Spacing="14" Margin="4,14,13,16">
                                                <Border Classes="settingsGroup">
                                                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                                                        <StackPanel Grid.Column="0" Spacing="4">
                                                            <TextBlock Classes="h2"
                                                                       Text="{DynamicResource MainWindow.Calendar.Title}" />
                                                            <TextBlock Classes="muted"
                                                                       Text="{DynamicResource MainWindow.Calendar.Description}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                        <Button Grid.Column="1"
                                                                Content="{DynamicResource MainWindow.Calendar.AddEntryButton}"
                                                                Command="{Binding AddCalendarEntryCommand}" />
                                                        <Button Grid.Column="2"
                                                                Content="{DynamicResource MainWindow.Calendar.ExportButton}"
                                                                Click="OnExportCalendarClick" />
                                                        <Button Grid.Column="3"
                                                                Content="{DynamicResource MainWindow.Calendar.ImportButton}"
                                                                Click="OnImportCalendarClick" />
                                                    </Grid>
                                                </Border>

                                                <Grid ColumnDefinitions="360,*" ColumnSpacing="14">
                                                    <Border Grid.Column="0" Classes="settingsGroup">
                                                        <StackPanel Spacing="10">
                                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                                <Button Grid.Column="0"
                                                                        Classes="iconsquare"
                                                                        Command="{Binding PreviousPlayerCalendarMonthCommand}"
                                                                        Content="&#8249;" />
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding PlayerCalendarMonthLabel}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontWeight="Bold" />
                                                                <Button Grid.Column="2"
                                                                        Classes="iconsquare"
                                                                        Command="{Binding NextPlayerCalendarMonthCommand}"
                                                                        Content="&#8250;" />
                                                            </Grid>

                                                            <UniformGrid Columns="7">
                                                                <TextBlock
                                                                    Text="{DynamicResource MainWindow.Calendar.MondayShort}"
                                                                    HorizontalAlignment="Center"
                                                                    Classes="muted" />
                                                                <TextBlock
                                                                    Text="{DynamicResource MainWindow.Calendar.TuesdayShort}"
                                                                    HorizontalAlignment="Center"
                                                                    Classes="muted" />
                                                                <TextBlock
                                                                    Text="{DynamicResource MainWindow.Calendar.WednesdayShort}"
                                                                    HorizontalAlignment="Center"
                                                                    Classes="muted" />
                                                                <TextBlock
                                                                    Text="{DynamicResource MainWindow.Calendar.ThursdayShort}"
                                                                    HorizontalAlignment="Center"
                                                                    Classes="muted" />
                                                                <TextBlock
                                                                    Text="{DynamicResource MainWindow.Calendar.FridayShort}"
                                                                    HorizontalAlignment="Center"
                                                                    Classes="muted" />
                                                                <TextBlock
                                                                    Text="{DynamicResource MainWindow.Calendar.SaturdayShort}"
                                                                    HorizontalAlignment="Center"
                                                                    Classes="muted" />
                                                                <TextBlock
                                                                    Text="{DynamicResource MainWindow.Calendar.SundayShort}"
                                                                    HorizontalAlignment="Center"
                                                                    Classes="muted" />
                                                            </UniformGrid>

                                                            <ItemsControl ItemsSource="{Binding PlayerCalendarDays}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <UniformGrid Columns="7" />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate
                                                                        x:DataType="viewModels:PlayerCalendarDayViewModel">
                                                                        <Button Classes="calendarDay"
                                                                                Classes.outside="{Binding !IsCurrentMonth}"
                                                                                Classes.selected="{Binding IsSelected}"
                                                                                Classes.today="{Binding IsToday}"
                                                                                Classes.hasEntries="{Binding HasEntries}"
                                                                                Command="{Binding SelectCommand}"
                                                                                Margin="2"
                                                                                MinHeight="44"
                                                                                HorizontalAlignment="Stretch"
                                                                                VerticalAlignment="Stretch"
                                                                                Padding="0">
                                                                            <TextBlock Text="{Binding DayNumber}"
                                                                                    HorizontalAlignment="Center" />
                                                                        </Button>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>

                                                    <StackPanel Grid.Column="1"
                                                                Spacing="14"
                                                                IsVisible="{Binding HasCalendarEntries}">
                                                        <Border Classes="settingsGroup"
                                                                IsVisible="{Binding HasSelectedCalendarEntry}">
                                                            <StackPanel Spacing="8">
                                                                <TextBlock Classes="settingsGroupTitle"
                                                                           Text="{Binding PlayerCalendarSelectedDateLabel}" />
                                                                <TextBlock Classes="muted"
                                                                           Text="{DynamicResource MainWindow.Calendar.NoEntriesForDay}"
                                                                           IsVisible="{Binding !HasCalendarEntriesForSelectedDate}" />
                                                                <ListBox
                                                                    ItemsSource="{Binding CalendarEntriesForSelectedDate}"
                                                                    SelectedItem="{Binding SelectedCalendarEntry}"
                                                                    IsVisible="{Binding HasCalendarEntriesForSelectedDate}"
                                                                    MinHeight="120">
                                                                    <ListBox.ItemTemplate>
                                                                        <DataTemplate
                                                                            x:DataType="viewModels:CalendarEntryViewModel">
                                                                            <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                                                                                    ColumnSpacing="10">
                                                                                <Border Grid.Column="0"
                                                                                    Width="6"
                                                                                    CornerRadius="3"
                                                                                    Background="{Binding ColorBrush}" />
                                                                                <PathIcon Grid.Column="1"
                                                                                    Data="{Binding IconGeometry}"
                                                                                    Width="18"
                                                                                    Height="18"
                                                                                    VerticalAlignment="Top" />
                                                                                <StackPanel Grid.Column="2" Spacing="3">
                                                                                    <TextBlock Text="{Binding Title}"
                                                                                        FontWeight="Bold" />
                                                                                    <TextBlock
                                                                                        Text="{Binding StartDateTimeText}"
                                                                                        Classes="muted" />
                                                                                </StackPanel>
                                                                                <TextBlock Grid.Column="3"
                                                                                    Text="{DynamicResource MainWindow.Calendar.PlayerLabel}"
                                                                                    Classes="muted"
                                                                                    IsVisible="{Binding IsPlayerVisible}" />
                                                                            </Grid>
                                                                        </DataTemplate>
                                                                    </ListBox.ItemTemplate>
                                                                </ListBox>
                                                            </StackPanel>
                                                        </Border>

                                                        <Border Classes="settingsGroup">
                                                            <StackPanel Spacing="10">
                                                                <TextBlock Classes="settingsGroupTitle"
                                                                           Text="{DynamicResource MainWindow.Calendar.EntryHeader}" />
                                                                <TextBlock Classes="muted"
                                                                           Text="{Binding SelectedCalendarEntry.ValidationMessage}"
                                                                           Foreground="{DynamicResource WarnBrush}"
                                                                           IsVisible="{Binding SelectedCalendarEntry.ValidationMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                                           TextWrapping="Wrap" />

                                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                                    <StackPanel Grid.Column="0" Spacing="4">
                                                                        <TextBlock Classes="muted"
                                                                                Text="{DynamicResource MainWindow.Calendar.TitleLabel}" />
                                                                        <TextBox
                                                                            Text="{Binding SelectedCalendarEntry.Title, Mode=TwoWay}" />
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="1" Spacing="4">
                                                                        <TextBlock Classes="muted"
                                                                                Text="{DynamicResource MainWindow.Calendar.IconLabel}" />
                                                                        <ComboBox ItemsSource="{Binding IconOptions}"
                                                                                SelectedItem="{Binding SelectedCalendarEntry.Icon, Mode=TwoWay}"
                                                                                Width="170" />
                                                                    </StackPanel>
                                                                </Grid>

                                                                <StackPanel Spacing="4">
                                                                    <TextBlock Classes="muted"
                                                                               Text="{DynamicResource MainWindow.Calendar.DescriptionLabel}" />
                                                                    <TextBox
                                                                        Text="{Binding SelectedCalendarEntry.Description, Mode=TwoWay}"
                                                                        AcceptsReturn="True"
                                                                        TextWrapping="Wrap"
                                                                        MinHeight="84" />
                                                                </StackPanel>

                                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                                                    <StackPanel Grid.Column="0" Spacing="4">
                                                                        <TextBlock Classes="muted"
                                                                                Text="{DynamicResource MainWindow.Calendar.StartLabel}" />
                                                                        <controls:DateTimeInput
                                                                            Text="{Binding SelectedCalendarEntry.StartDateTimeText, Mode=TwoWay}" />
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="1" Spacing="4">
                                                                        <TextBlock Classes="muted"
                                                                                Text="{DynamicResource MainWindow.Calendar.EndDateLabel}" />
                                                                        <TextBox
                                                                            Text="{Binding SelectedCalendarEntry.RepeatUntilText, Mode=TwoWay}"
                                                                            PlaceholderText="YYYY-MM-DD" />
                                                                    </StackPanel>
                                                                </Grid>

                                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                                    <StackPanel Grid.Column="0" Spacing="4">
                                                                        <TextBlock Classes="muted"
                                                                                Text="{DynamicResource MainWindow.Common.Repeat}" />
                                                                        <ComboBox
                                                                            ItemsSource="{Binding CalendarRecurrenceOptions}"
                                                                            SelectedItem="{Binding SelectedCalendarEntry.Recurrence, Mode=TwoWay}"
                                                                            HorizontalAlignment="Stretch" />
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="1" Spacing="4">
                                                                        <TextBlock Classes="muted"
                                                                                Text="{DynamicResource MainWindow.Common.Color}" />
                                                                        <ColorPicker
                                                                            Color="{Binding SelectedCalendarEntry.ColorHex, Converter={x:Static conv:HexColorConverter.Instance}, Mode=TwoWay}"
                                                                            ToolTip.Tip="{DynamicResource MainWindow.Calendar.ColorTooltip}" />
                                                                    </StackPanel>
                                                                </Grid>

                                                                <CheckBox
                                                                    Content="{DynamicResource MainWindow.Calendar.PlayerVisibleCheckbox}"
                                                                    IsChecked="{Binding SelectedCalendarEntry.IsPlayerVisible, Mode=TwoWay}" />

                                                                <Border Background="{DynamicResource SurfaceBrush}"
                                                                        BorderBrush="{DynamicResource InnerFrameBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="6"
                                                                        Padding="10">
                                                                    <StackPanel Spacing="8">
                                                                        <TextBlock Classes="muted"
                                                                                Text="{DynamicResource MainWindow.Calendar.TriggerMediaLabel}" />
                                                                        <ComboBox ItemsSource="{Binding MediaLibrary}"
                                                                                SelectedItem="{Binding SelectedCalendarTriggerMediaItem, Mode=TwoWay}">
                                                                            <ComboBox.ItemTemplate>
                                                                                <DataTemplate
                                                                                    x:DataType="vm:MediaLibraryItemViewModel">
                                                                                    <TextBlock Text="{Binding Name}" />
                                                                                </DataTemplate>
                                                                            </ComboBox.ItemTemplate>
                                                                        </ComboBox>

                                                                        <TextBlock Classes="muted"
                                                                                Text="{DynamicResource MainWindow.Calendar.TriggerSoundLabel}" />
                                                                        <ComboBox ItemsSource="{Binding SoundLibrary}"
                                                                                SelectedItem="{Binding SelectedCalendarTriggerSoundItem, Mode=TwoWay}">
                                                                            <ComboBox.ItemTemplate>
                                                                                <DataTemplate
                                                                                    x:DataType="vm:SoundLibraryItemViewModel">
                                                                                    <TextBlock Text="{Binding Name}" />
                                                                                </DataTemplate>
                                                                            </ComboBox.ItemTemplate>
                                                                        </ComboBox>

                                                                        <TextBlock Classes="muted"
                                                                                Text="{Binding SelectedCalendarEntry.TriggerSummary}"
                                                                                TextWrapping="Wrap" />

                                                                        <StackPanel Orientation="Horizontal"
                                                                                Spacing="12"
                                                                                IsVisible="{Binding SelectedCalendarEntry.TriggerMedia.HasMedia}">
                                                                            <CheckBox
                                                                                Content="{DynamicResource MainWindow.Calendar.FullscreenCheckbox}"
                                                                                IsChecked="{Binding SelectedCalendarEntry.TriggerMedia.Fullscreen, Mode=TwoWay}" />
                                                                            <CheckBox
                                                                                Content="{DynamicResource MainWindow.Calendar.PauseClockCheckbox}"
                                                                                IsChecked="{Binding SelectedCalendarEntry.TriggerMedia.PauseClockDuringVideo, Mode=TwoWay}"
                                                                                IsVisible="{Binding SelectedCalendarEntry.TriggerMedia.IsVideo}" />
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                </Border>

                                                                <Button
                                                                    Content="{DynamicResource MainWindow.Calendar.DeleteEntryButton}"
                                                                    Command="{Binding SelectedCalendarEntry.DeleteCommand}"
                                                                    HorizontalAlignment="Right" />
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </TabItem>

                                    <TabItem Header="{DynamicResource MainWindow.Tabs.Settings}">
                                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                                      VerticalScrollBarVisibility="Visible" AllowAutoHide="false">
                                            <WrapPanel Orientation="Horizontal" Margin="4,14,13,16">
                                                    <Border Classes="settingsGroup" Width="520" Margin="0,0,14,14">
                                                        <StackPanel Spacing="10">
                                                            <TextBlock Classes="settingsGroupTitle"
                                                                       Text="{DynamicResource MainWindow.Settings.AppearanceHeader}" />
                                                            <StackPanel Spacing="4">
                                                                <TextBlock Classes="muted"
                                                                           Text="{DynamicResource MainWindow.Settings.StyleLabel}" />
                                                                <ComboBox ItemsSource="{Binding ThemeOptions}"
                                                                          SelectedItem="{Binding SelectedThemeOption}"
                                                                          HorizontalAlignment="Stretch" />
                                                                <CheckBox
                                                                    Content="{DynamicResource MainWindow.Settings.AmbienceAutomationCheckbox}"
                                                                    IsChecked="{Binding AmbienceAutomationEnabled, Mode=TwoWay}"
                                                                    IsEnabled="{Binding HasAmbienceBackgrounds}"
                                                                    ToolTip.Tip="{DynamicResource MainWindow.Settings.AmbienceAutomationTooltip}" />
                                                            </StackPanel>
                                                            <Separator Background="{DynamicResource BorderBrush}" />
                                                            <StackPanel Spacing="4">
                                                                <TextBlock Classes="muted"
                                                                           Text="{DynamicResource Settings.Language}" />
                                                                <ComboBox ItemsSource="{Binding LanguageOptions}"
                                                                          SelectedItem="{Binding SelectedLanguageOption}"
                                                                          HorizontalAlignment="Stretch" />
                                                            </StackPanel>
                                                            <Separator Background="{DynamicResource BorderBrush}" />
                                                            <StackPanel Spacing="4">
                                                                <TextBlock Classes="muted"
                                                                           Text="{DynamicResource MainWindow.Settings.PlayerWindowTitleLabel}" />
                                                                <TextBox
                                                                    Text="{Binding PlayerHeaderTitle, Mode=TwoWay}"
                                                                    PlaceholderText="{DynamicResource MainWindow.Settings.PlayerWindowTitlePlaceholder}" />
                                                                <TextBox
                                                                    Text="{Binding PlayerHeaderSubtitle, Mode=TwoWay}"
                                                                    PlaceholderText="{DynamicResource MainWindow.Settings.PlayerWindowSubtitlePlaceholder}" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Classes="settingsGroup" Width="520" Margin="0,0,14,14">
                                                        <StackPanel Spacing="10">
                                                            <TextBlock Classes="settingsGroupTitle"
                                                                       Text="{DynamicResource MainWindow.Settings.HeadsUpHeader}" />
                                                            <StackPanel Spacing="4">
                                                                <CheckBox
                                                                    Content="{DynamicResource MainWindow.Settings.HeadsUpCheckbox}"
                                                                    IsChecked="{Binding HeadsUpWarningEnabled, Mode=TwoWay}" />
                                                                <Grid ColumnDefinitions="Auto,Auto"
                                                                      IsEnabled="{Binding HeadsUpWarningEnabled}">
                                                                    <TextBlock Grid.Column="0" Classes="muted"
                                                                               Text="{DynamicResource MainWindow.Settings.HeadsUpLeadLabel}"
                                                                               VerticalAlignment="Center"
                                                                               Margin="0,0,10,0" />
                                                                    <NumericUpDown Grid.Column="1"
                                                                            Value="{Binding HeadsUpLeadMinutes, Mode=TwoWay}"
                                                                            Minimum="0.1" Maximum="60" Increment="0.5"
                                                                            FormatString="0.0"
                                                                            NumberFormat="{DynamicResource App.NumberFormat}"
                                                                            Width="110" />
                                                                </Grid>
                                                                <TextBlock Classes="muted"
                                                                           Text="{DynamicResource MainWindow.Settings.HeadsUpDescription}"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border Classes="settingsGroup" Width="520" Margin="0,0,14,14">
                                                        <StackPanel Spacing="10">
                                                            <TextBlock Classes="settingsGroupTitle"
                                                                       Text="{DynamicResource MainWindow.Settings.NetworkHeader}" />
                                                            <StackPanel Spacing="4">
                                                                <TextBlock Classes="muted"
                                                                           Text="{DynamicResource MainWindow.Settings.ServerNameLabel}" />
                                                                <TextBox Text="{Binding ServerName, Mode=TwoWay}"
                                                                         PlaceholderText="{DynamicResource MainWindow.Settings.ServerNamePlaceholder}"
                                                                         MaxLength="60" />
                                                                <TextBlock Classes="muted"
                                                                           Text="{DynamicResource MainWindow.Settings.PinLabel}" />
                                                                <TextBox Text="{Binding ConnectionPin, Mode=TwoWay}"
                                                                         PasswordChar="•"
                                                                         PlaceholderText="{DynamicResource MainWindow.Settings.PinPlaceholder}"
                                                                         MaxLength="32" />
                                                                <Grid ColumnDefinitions="*,Auto">
                                                                    <NumericUpDown Grid.Column="0"
                                                                            Value="{Binding NetworkServerPort}"
                                                                            Minimum="1"
                                                                            Maximum="65535"
                                                                            FormatString="0"
                                                                            Margin="0,0,8,0" />
                                                                    <Button Grid.Column="1"
                                                                            Content="{Binding ToggleNetworkServerLabel}"
                                                                            Command="{Binding ToggleNetworkServerCommand}" />
                                                                </Grid>
                                                                <TextBlock Classes="muted"
                                                                           Text="{Binding NetworkServerStatus}"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock Classes="muted"
                                                                           Text="{DynamicResource MainWindow.Settings.NetworkDescription}"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border Classes="settingsGroup" Width="520" Margin="0,0,14,14">
                                                        <StackPanel Spacing="10">
                                                            <TextBlock Classes="settingsGroupTitle"
                                                                       Text="{DynamicResource MainWindow.Settings.ConnectedClientsLabel}" />
                                                            <StackPanel Spacing="4">
                                                                <TextBlock Classes="muted"
                                                                           Text="{DynamicResource MainWindow.Music.RoutingDescription}"
                                                                           TextWrapping="Wrap" />
                                                                <Grid ColumnDefinitions="*,Auto">
                                                                    <TextBlock Grid.Column="0" Classes="muted"
                                                                               Text="{DynamicResource MainWindow.Settings.SoundSeekThresholdLabel}"
                                                                               VerticalAlignment="Center"
                                                                               TextWrapping="Wrap"
                                                                               Margin="0,0,8,0" />
                                                                    <NumericUpDown Grid.Column="1"
                                                                            Value="{Binding SoundSeekThresholdMs}"
                                                                            Minimum="0" Maximum="600000"
                                                                            Increment="1000" FormatString="0"
                                                                            NumberFormat="{DynamicResource App.NumberFormat}"
                                                                            Width="140"
                                                                            ToolTip.Tip="{DynamicResource MainWindow.Settings.SoundSeekThresholdTooltip}" />
                                                                </Grid>
                                                                <TextBlock Classes="muted"
                                                                           Text="{DynamicResource MainWindow.Settings.NoConnectedClients}"
                                                                           IsVisible="{Binding HasNoConnectedClients}"
                                                                           FontStyle="Italic" />
                                                                <WrapPanel Orientation="Horizontal">
                                                                    <Border Classes="item" Width="280"
                                                                            HorizontalAlignment="Left">
                                                                        <StackPanel Spacing="6">
                                                                            <TextBlock
                                                                                Text="{DynamicResource MainWindow.Music.RoutingHostLabel}"
                                                                                FontWeight="Bold"
                                                                                TextTrimming="CharacterEllipsis" />
                                                                            <StackPanel Orientation="Horizontal"
                                                                                Spacing="10">
                                                                                <CheckBox
                                                                                    Content="{DynamicResource MainWindow.Music.RoutingMusicCheckbox}"
                                                                                    IsChecked="{Binding PlayMusicLocally}" />
                                                                                <CheckBox
                                                                                    Content="{DynamicResource MainWindow.Music.RoutingSoundCheckbox}"
                                                                                    IsChecked="{Binding PlaySoundLocally}" />
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <ItemsControl
                                                                        ItemsSource="{Binding ConnectedClientItems}">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <WrapPanel Orientation="Horizontal" />
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate
                                                                                x:DataType="vm:ConnectedClientItemViewModel">
                                                                                <Border Classes="item" Width="280">
                                                                                    <StackPanel Spacing="6">
                                                                                        <Grid
                                                                                            ColumnDefinitions="*,Auto">
                                                                                            <StackPanel
                                                                                                Grid.Column="0"
                                                                                                TextBlock.TextTrimming="CharacterEllipsis">
                                                                                                <TextBlock
                                                                                                    Text="{Binding RemoteEndpoint}"
                                                                                                    FontWeight="Bold"
                                                                                                    TextTrimming="CharacterEllipsis" />
                                                                                                <TextBlock
                                                                                                    Classes="muted"
                                                                                                    Text="{Binding ConnectedSinceDisplay}" />
                                                                                            </StackPanel>
                                                                                            <Button
                                                                                                Grid.Column="1"
                                                                                                Classes="iconsquare"
                                                                                                Content="&#10005;"
                                                                                                Width="22"
                                                                                                Height="22"
                                                                                                FontSize="10"
                                                                                                Command="{Binding DisconnectCommand}"
                                                                                                ToolTip.Tip="{DynamicResource MainWindow.Settings.DisconnectTooltip}" />
                                                                                        </Grid>
                                                                                        <WrapPanel
                                                                                            Orientation="Horizontal">
                                                                                            <CheckBox
                                                                                                Margin="0,0,10,4"
                                                                                                Content="{DynamicResource MainWindow.Music.RoutingMusicCheckbox}"
                                                                                                IsChecked="{Binding MusicEnabled}" />
                                                                                            <CheckBox
                                                                                                Margin="0,0,10,4"
                                                                                                Content="{DynamicResource MainWindow.Music.RoutingSoundCheckbox}"
                                                                                                IsChecked="{Binding SoundEnabled}" />
                                                                                            <CheckBox
                                                                                                Margin="0,0,10,4"
                                                                                                Content="{DynamicResource MainWindow.Music.RoutingImageCheckbox}"
                                                                                                IsChecked="{Binding ImageEnabled}" />
                                                                                            <CheckBox
                                                                                                Margin="0,0,10,4"
                                                                                                Content="{DynamicResource MainWindow.Music.RoutingVideoCheckbox}"
                                                                                                IsChecked="{Binding VideoEnabled}" />
                                                                                            <CheckBox
                                                                                                Margin="0,0,10,4"
                                                                                                Content="{DynamicResource MainWindow.Music.RoutingMapCheckbox}"
                                                                                                IsChecked="{Binding MapEnabled}" />
                                                                                        </WrapPanel>
                                                                                    </StackPanel>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </WrapPanel>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border Classes="settingsGroup" Width="520" Margin="0,0,14,14">
                                                        <StackPanel Spacing="10">
                                                            <TextBlock Classes="settingsGroupTitle"
                                                                       Text="{DynamicResource MainWindow.Settings.SlideshowHeader}" />
                                                            <StackPanel Spacing="4">
                                                                <Grid ColumnDefinitions="Auto,*">
                                                                    <TextBlock Grid.Column="0" Classes="muted"
                                                                               Text="{DynamicResource MainWindow.Settings.SecondsPerImageLabel}"
                                                                               VerticalAlignment="Center"
                                                                               Margin="0,0,8,0" />
                                                                    <NumericUpDown Grid.Column="1"
                                                                            Value="{Binding SlideshowSecondsPerImage}"
                                                                            Minimum="0" FormatString="0"
                                                                            NumberFormat="{DynamicResource App.NumberFormat}"
                                                                            HorizontalAlignment="Stretch"
                                                                            ToolTip.Tip="{DynamicResource MainWindow.Settings.SlideshowTooltip}" />
                                                                </Grid>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border Classes="settingsGroup" Width="520" Margin="0,0,14,14">
                                                        <StackPanel Spacing="10">
                                                            <TextBlock Classes="settingsGroupTitle"
                                                                       Text="{DynamicResource MainWindow.Settings.SessionLogHeader}" />
                                                            <StackPanel Spacing="4">
                                                                <CheckBox
                                                                    Content="{DynamicResource MainWindow.Settings.RecordSessionLogCheckbox}"
                                                                    IsChecked="{Binding RecordSessionLog, Mode=TwoWay}" />
                                                                <Grid ColumnDefinitions="*,Auto">
                                                                    <Button Grid.Column="0"
                                                                            Content="{DynamicResource MainWindow.Settings.ExportLogButton}"
                                                                            Click="OnExportSessionLogClick"
                                                                            IsEnabled="{Binding HasSessionLogEntries}"
                                                                            HorizontalAlignment="Stretch"
                                                                            Margin="0,0,6,0" />
                                                                    <Button Grid.Column="1"
                                                                            Content="{DynamicResource MainWindow.Settings.ClearLogButton}"
                                                                            Command="{Binding ClearSessionLogCommand}"
                                                                            IsEnabled="{Binding HasSessionLogEntries}" />
                                                                </Grid>
                                                                <Border Background="{DynamicResource SurfaceBrush}"
                                                                        BorderBrush="{DynamicResource InnerFrameBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="6"
                                                                        Padding="8"
                                                                        MaxHeight="140"
                                                                        IsVisible="{Binding HasSessionLogEntries}">
                                                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                                            AllowAutoHide="false">
                                                                        <ItemsControl
                                                                            ItemsSource="{Binding SessionLogEntries}">
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate x:DataType="x:String">
                                                                                    <TextBlock Text="{Binding}"
                                                                                        Classes="muted"
                                                                                        TextWrapping="Wrap" />
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>
                                                                    </ScrollViewer>
                                                                </Border>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border Classes="settingsGroup" Width="520" Margin="0,0,14,14">
                                                        <StackPanel Spacing="10">
                                                            <TextBlock Classes="settingsGroupTitle"
                                                                       Text="{DynamicResource MainWindow.Settings.SaveLoadHeader}" />
                                                            <StackPanel Spacing="4">
                                                                <CheckBox
                                                                    Content="{DynamicResource MainWindow.Settings.AutoSaveOnCloseCheckbox}"
                                                                    IsChecked="{Binding AutoSaveOnCloseEnabled, Mode=TwoWay}" />
                                                                <CheckBox
                                                                    Content="{DynamicResource MainWindow.Settings.AutoLoadOnStartupCheckbox}"
                                                                    IsChecked="{Binding AutoLoadOnStartupEnabled, Mode=TwoWay}" />
                                                                <TextBlock Classes="muted"
                                                                           Text="{DynamicResource MainWindow.Settings.AutoSaveLoadDescription}"
                                                                           TextWrapping="Wrap" />
                                                                <Separator Background="{DynamicResource BorderBrush}" />
                                                                <Grid ColumnDefinitions="*,*">
                                                                    <Button Grid.Column="0"
                                                                            Content="{DynamicResource MainWindow.Settings.ExportSessionButton}"
                                                                            Click="OnExportFullSessionClick"
                                                                            HorizontalAlignment="Stretch"
                                                                            HorizontalContentAlignment="Center"
                                                                            Margin="0,0,4,0" />
                                                                    <Button Grid.Column="1"
                                                                            Content="{DynamicResource MainWindow.Settings.ImportSessionButton}"
                                                                            Click="OnImportFullSessionClick"
                                                                            HorizontalAlignment="Stretch"
                                                                            HorizontalContentAlignment="Center" />
                                                                </Grid>
                                                <TextBlock Classes="muted"
                                                                           Text="{DynamicResource MainWindow.Settings.SessionExportDescription}"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border Classes="settingsGroup" Width="520" Margin="0,0,14,14">
                                                        <StackPanel Spacing="10">
                                                            <TextBlock Classes="settingsGroupTitle"
                                                                       Text="{DynamicResource MainWindow.Settings.FogOfWarHeader}" />
                                                            <TextBlock Classes="muted"
                                                                       Text="{DynamicResource MainWindow.Settings.FogOfWarDescription}"
                                                                       TextWrapping="Wrap" />
                                                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto"
                                                                  ColumnSpacing="10" RowSpacing="8">
                                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                                           Text="{DynamicResource MainWindow.Settings.FogColorLabel}"
                                                                           VerticalAlignment="Center" />
                                                                <ColorPicker Grid.Row="0" Grid.Column="1"
                                                                             HorizontalAlignment="Left"
                                                                             Color="{Binding FogColorHex, Converter={x:Static conv:HexColorConverter.Instance}, Mode=TwoWay}" />

                                                                <TextBlock Grid.Row="1" Grid.Column="0"
                                                                           Text="{DynamicResource MainWindow.Settings.FogOpacityLabel}"
                                                                           VerticalAlignment="Center" />
                                                                <Grid Grid.Row="1" Grid.Column="1"
                                                                      ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                                    <Slider Grid.Column="0" Minimum="0" Maximum="100"
                                                                            Value="{Binding FogOpacityPercent, Mode=TwoWay}" />
                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{Binding FogOpacityPercent, StringFormat='{}{0}%'}"
                                                                               VerticalAlignment="Center" />
                                                                </Grid>

                                                                <TextBlock Grid.Row="2" Grid.Column="0"
                                                                           Text="{DynamicResource MainWindow.Settings.FogBlurEnabledLabel}"
                                                                           VerticalAlignment="Center" />
                                                                <CheckBox Grid.Row="2" Grid.Column="1"
                                                                          IsChecked="{Binding FogBlurEnabled, Mode=TwoWay}" />

                                                                <TextBlock Grid.Row="3" Grid.Column="0"
                                                                           Text="{DynamicResource MainWindow.Settings.FogBlurLabel}"
                                                                           VerticalAlignment="Center" />
                                                                <Grid Grid.Row="3" Grid.Column="1"
                                                                      ColumnDefinitions="*,Auto" ColumnSpacing="8"
                                                                      IsEnabled="{Binding FogBlurEnabled}">
                                                                    <Slider Grid.Column="0" Minimum="0" Maximum="60"
                                                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                                                            Value="{Binding FogBlurRadius, Mode=TwoWay}" />
                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{Binding FogBlurRadius, StringFormat='{}{0:0}px'}"
                                                                               VerticalAlignment="Center" />
                                                                </Grid>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Border>
                                            </WrapPanel>
                                        </ScrollViewer>
                                    </TabItem>
                                </TabControl>
                            </DockPanel>
                        </Border>
                    </Grid>

                    <!-- Statusleiste: bleibt bei jedem Tab-Wechsel gleich hoch (siehe design-decisions.md
                     "Statusleiste statt reflow-anfälliger Tab-Inhalte") - Serverstatus, aktuelles
                     Bild/Video (mit Schließen-Button) und Benachrichtigungen, damit hier nie etwas
                     "springt". -->
                    <Border Grid.Row="3" Classes="card" MinHeight="50" Margin="0,12,0,0" Padding="14,8">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Ellipse Width="9" Height="9" Fill="{DynamicResource OkBrush}"
                                         IsVisible="{Binding IsNetworkServerRunning}" />
                                <Ellipse Width="9" Height="9" Fill="{DynamicResource BorderBrush}"
                                         IsVisible="{Binding !IsNetworkServerRunning}" />
                                <TextBlock Text="{Binding ServerStatusSummary}" Classes="muted"
                                           VerticalAlignment="Center" />
                                <TextBlock Classes="muted"
                                           Text="{Binding MediaErrorMessage}"
                                           IsVisible="{Binding MediaErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           Foreground="{DynamicResource WarnBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center"
                                        IsVisible="{Binding HasMedia}" Margin="16,0">
                                <TextBlock Text="🖼" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <Button Classes="iconsquare" Content="&#8249;" Width="22" Height="22" FontSize="12"
                                        Command="{Binding PreviousGalleryItemCommand}"
                                        ToolTip.Tip="{DynamicResource MainWindow.StatusBar.PreviousGalleryTooltip}"
                                        IsVisible="{Binding !HasNoSentMediaItems}" />
                                <TextBlock Text="{Binding CurrentMediaFileName}" Classes="muted" MaxWidth="200"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                <Button Classes="iconsquare" Content="&#8250;" Width="22" Height="22" FontSize="12"
                                        Command="{Binding NextGalleryItemCommand}"
                                        ToolTip.Tip="{DynamicResource MainWindow.StatusBar.NextGalleryTooltip}"
                                        IsVisible="{Binding !HasNoSentMediaItems}" />
                                <Button Classes="iconsquare" Content="&#10005;" Width="22" Height="22" FontSize="10"
                                        Command="{Binding ClearMediaCommand}"
                                        ToolTip.Tip="{DynamicResource MainWindow.StatusBar.CloseMediaTooltip}"
                                        Margin="6,0,0,0" />
                            </StackPanel>

                            <!-- Immer sichtbar (nicht IsVisible-gebunden) und fest 22x22 - eine feste
                             Spaltenbreite, die sich nie ändert, egal ob/wie viele Benachrichtigungen
                             es gibt. Der Punkt zeigt nur an, ob gerade eine neue (noch nicht
                             abgelaufene) Meldung ansteht; der Verlauf im Flyout bleibt unabhängig
                             davon erhalten. -->
                            <Button Grid.Column="3" Classes="iconsquare" Width="22" Height="22" FontSize="12"
                                    Margin="10,0,0,0"
                                    ToolTip.Tip="{DynamicResource MainWindow.StatusBar.NotificationsTooltip}">
                                <Panel>
                                    <TextBlock Text="🔔" />
                                    <Ellipse Width="7" Height="7" Fill="{DynamicResource OkBrush}"
                                             HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0"
                                             IsVisible="{Binding ActionStatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                </Panel>
                                <Button.Flyout>
                                    <Flyout Placement="TopEdgeAlignedRight">
                                        <StackPanel Spacing="8" Width="300" Margin="4">
                                            <TextBlock Classes="h2"
                                                       Text="{DynamicResource MainWindow.StatusBar.NotificationsHeader}" />
                                            <ItemsControl ItemsSource="{Binding ActionStatusHistory}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="x:String">
                                                        <TextBlock Text="{Binding}" Classes="muted" TextWrapping="Wrap"
                                                                   Margin="0,0,0,4" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Classes="muted"
                                                       Text="{DynamicResource MainWindow.StatusBar.NoNotifications}"
                                                       IsVisible="{Binding HasNoActionStatusHistory}" />
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>

                            <!-- Ein gemeinsamer Vollbild-Schalter für lokales Spielerfenster und
                             Remote-Clients; was tatsächlich geschaltet wird, entscheidet das
                             ViewModel anhand der gerade verfügbaren Ziele. -->
                            <Button Grid.Column="4"
                                    Classes="iconsquare"
                                    Classes.active="{Binding IsDisplayFullscreenActive}"
                                    Width="22"
                                    Height="22"
                                    FontSize="12"
                                    Margin="10,0,0,0"
                                    Content="&#9974;"
                                    Command="{Binding ToggleDisplayFullscreenCommand}"
                                    IsEnabled="{Binding CanToggleDisplayFullscreen}"
                                    ToolTip.Tip="{Binding DisplayFullscreenLabel}" />
                        </Grid>
                    </Border>
                </Grid>
            </Panel>
        </Border>
    </Panel>
</Window>