<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="using:RpgTimeTracker.Shared.ViewModels"
             xmlns:rpc="using:RpgTimeTracker.Shared.Models.Rpc"
             x:Class="RpgTimeTracker.Shared.Views.MapDisplayView"
             x:DataType="viewModels:MapDisplayViewModel">

    <!-- Shared by the Host's local player-window preview (PlayerWindow.axaml) and the real
         PlayerClient (MediaWindow.axaml) - both set DataContext="{Binding MapDisplay}" on this
         control, see MapDisplayViewModel. Three layers, all sized identically via the inner
         fixed-size Panel (so they line up regardless of window aspect ratio, unlike a plain
         Stretch="Uniform" Rectangle which wouldn't letterbox the same way an Image does):
           1. The sharp floor image, always visible.
           2. A blurred copy of the SAME image, clipped to hidden cells via MaskBrush - blurring
              the actual map content (not a flat fog-colored blob) so the blur is visible at all.
           3. A color-tint layer, also clipped via MaskBrush, applied on top of the blur.
         Cell edges stay crisp; the blur shows up in the content peeking through, not the
         boundary shape. -->
    <Panel IsVisible="{Binding IsShowingMap}">
        <Viewbox Stretch="Uniform">
            <Panel Width="{Binding CurrentFloorImageBitmap.PixelSize.Width}"
                   Height="{Binding CurrentFloorImageBitmap.PixelSize.Height}">
                <Image Source="{Binding CurrentFloorImageBitmap}" Stretch="Fill" />
                <Image Source="{Binding CurrentFloorImageBitmap}" Stretch="Fill"
                       OpacityMask="{Binding MaskBrush}" IsVisible="{Binding ShowBlurLayer}">
                    <Image.Effect>
                        <BlurEffect Radius="{Binding BlurRadius}" />
                    </Image.Effect>
                </Image>
                <Rectangle Fill="{Binding TintBrush}" OpacityMask="{Binding MaskBrush}"
                           IsVisible="{Binding HasFogMask}" />

                <!-- Token overlay - already fully resolved/filtered by the Host (see
                     MapTokenSnapshotDto), this side has no extra visibility logic to apply, just
                     renders whatever's in VisibleTokens (current floor only). -->
                <ItemsControl ItemsSource="{Binding VisibleTokens}">
                    <!-- Canvas only positions its OWN direct children - the generated item
                         container (a ContentPresenter), not an arbitrary element nested inside
                         the ItemTemplate's content. Canvas.Left/Top must be set here, targeting
                         that container, not on the Border below (setting it there compiled and
                         "rendered" fine, but every token silently piled up at the Canvas's
                         default (0,0) instead of its real position - a classic Canvas+ItemsControl
                         pitfall neither a compile check nor a size-only render test would catch). -->
                    <ItemsControl.Styles>
                        <Style Selector="ContentPresenter" x:DataType="rpc:MapTokenSnapshotDto">
                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                        </Style>
                    </ItemsControl.Styles>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="rpc:MapTokenSnapshotDto">
                            <!-- The container above is positioned at the token's raw (X,Y) - its
                                 center, matching MapEditCanvasControl's own marker placement - so
                                 this Border shifts itself to center on that point via a plain
                                 static RenderTransform (half its own 32px size). -->
                            <Border Width="32" Height="32" CornerRadius="16" ClipToBounds="True"
                                    Background="Black" BorderBrush="White" BorderThickness="2"
                                    RenderTransform="translate(-16px, -16px)"
                                    ToolTip.Tip="{Binding Name}">
                                <TextBlock Text="{Binding Name}" FontSize="10" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" MaxWidth="30" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Panel>
        </Viewbox>

        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center"
                    VerticalAlignment="Bottom" Margin="0,0,0,16" IsVisible="{Binding HasMultipleFloors}">
            <Button Content="&#8249;" Command="{Binding PreviousFloorCommand}"
                    Background="#66000000" Foreground="White" BorderThickness="0" />
            <Border Background="#66000000" CornerRadius="6" Padding="10,6">
                <TextBlock Text="{Binding CurrentFloorName}" Foreground="White" />
            </Border>
            <Button Content="&#8250;" Command="{Binding NextFloorCommand}"
                    Background="#66000000" Foreground="White" BorderThickness="0" />
        </StackPanel>
    </Panel>
</UserControl>