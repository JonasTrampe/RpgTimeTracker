<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="using:RpgTimeTracker.Shared.ViewModels"
             xmlns:rpc="using:RpgTimeTracker.Shared.Models.Rpc"
             x:Class="RpgTimeTracker.Shared.Views.MapDisplayView"
             x:DataType="viewModels:MapDisplayViewModel"
             x:Name="Self">

    <!-- Shared by the Host's local player-window preview (PlayerWindow.axaml) and the real
         PlayerClient (MediaWindow.axaml) - both set DataContext="{Binding MapDisplay}" on this
         control, see MapDisplayViewModel. Three layers, all sized identically via the inner
         fixed-size Panel (so they line up regardless of window aspect ratio, unlike a plain
         Stretch="Uniform" Rectangle which wouldn't letterbox the same way an Image does):
           1. The sharp floor image, always visible.
           2. A blurred copy of the SAME image, clipped to hidden cells via MaskBrush - blurring
              the actual map content (not a flat fog-colored blob) so the blur is visible at all.
           3. A color-tint layer, also clipped via MaskBrush, applied on top of the blur.
         Cell edges stay crisp; the blur shows up in the content peeking through, not the
         boundary shape. -->
    <Panel IsVisible="{Binding IsShowingMap}">
        <!-- ScrollViewer + LayoutTransformControl replaces a plain fit-to-container Viewbox so
             players can independently zoom/pan (#71's "add zoom to the player window") - a
             LayoutTransformControl scales its child for rendering AND reports the scaled size to
             its own parent for the ScrollViewer's scroll bounds, so every existing binding below
             (native-pixel-space image size, token X/Y via the ContentPresenter Style) needs no
             change at all - only MapDisplayView.axaml.cs's zoom math cares about the scale. -->
        <!-- Centering matters once zoomed out below "fit": ScrollViewer's own
             HorizontalContentAlignment/VerticalContentAlignment turned out unreliable here (still
             pinned content to one side) - aligning the LayoutTransformControl itself within the
             ScrollViewer's content area is what Avalonia's arrange pass actually honors, same as
             centering any other child smaller than its available space. -->
        <ScrollViewer Name="ScrollHost" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      PointerWheelChanged="OnPointerWheelChanged">
            <LayoutTransformControl Name="ZoomHost" HorizontalAlignment="Center" VerticalAlignment="Center">
                <LayoutTransformControl.LayoutTransform>
                    <ScaleTransform />
                </LayoutTransformControl.LayoutTransform>
                <Panel x:Name="ImageContentPanel" Width="{Binding CurrentFloorImageBitmap.PixelSize.Width}"
                       Height="{Binding CurrentFloorImageBitmap.PixelSize.Height}">
                <Image Source="{Binding CurrentFloorImageBitmap}" Stretch="Fill" />
                <Image Source="{Binding CurrentFloorImageBitmap}" Stretch="Fill"
                       OpacityMask="{Binding MaskBrush}" IsVisible="{Binding ShowBlurLayer}">
                    <Image.Effect>
                        <BlurEffect Radius="{Binding BlurRadius}" />
                    </Image.Effect>
                </Image>
                <Rectangle Fill="{Binding TintBrush}" OpacityMask="{Binding MaskBrush}"
                           IsVisible="{Binding HasFogMask}" />

                <!-- Token overlay - already fully resolved/filtered by the Host (see
                     MapTokenSnapshotDto), this side has no extra visibility logic to apply, just
                     renders whatever's in VisibleTokens (current floor only). -->
                <ItemsControl ItemsSource="{Binding VisibleTokens}">
                    <!-- Canvas only positions its OWN direct children - the generated item
                         container (a ContentPresenter), not an arbitrary element nested inside
                         the ItemTemplate's content. Canvas.Left/Top must be set here, targeting
                         that container, not on the Border below (setting it there compiled and
                         "rendered" fine, but every token silently piled up at the Canvas's
                         default (0,0) instead of its real position - a classic Canvas+ItemsControl
                         pitfall neither a compile check nor a size-only render test would catch). -->
                    <ItemsControl.Styles>
                        <Style Selector="ContentPresenter" x:DataType="rpc:MapTokenSnapshotDto">
                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                        </Style>
                    </ItemsControl.Styles>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="rpc:MapTokenSnapshotDto">
                            <!-- Positioned at the token's raw (X,Y) - its center, matching
                                 MapEditCanvasControl's own marker placement - the whole Panel
                                 (sized to its largest child, the 40px current-turn ring) shifts
                                 itself to center on that point via a plain static RenderTransform. -->
                            <Panel RenderTransform="translate(-20px, -20px)">
                                <!-- Current-turn highlight ring (#70) - a token's own toggles
                                     never gate this: it's a GM-driven state, not player-visible
                                     data the token itself opts into showing. -->
                                <Border Width="40" Height="40" CornerRadius="20" BorderThickness="3"
                                        BorderBrush="Gold" HorizontalAlignment="Center" VerticalAlignment="Center"
                                        IsVisible="{Binding IsCurrentTurn}" />
                                <Border Width="32" Height="32" CornerRadius="16" ClipToBounds="True"
                                        Background="Black" BorderBrush="White" BorderThickness="2"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <ToolTip.Tip>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                       IsVisible="{Binding Name, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                            <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" MaxWidth="260"
                                                       IsVisible="{Binding Detail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                            <!-- Plain text, not rendered as Markdown despite PlayerInfo being
                                                 Markdown-authored (matches the About screen's renderer) - a
                                                 ToolTip is a lightweight hover affordance, not worth pulling a
                                                 Markdown control into; can be revisited if plain text reads
                                                 poorly in practice. -->
                                            <TextBlock Text="{Binding PlayerInfo}" TextWrapping="Wrap" MaxWidth="260"
                                                       IsVisible="{Binding PlayerInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                        </StackPanel>
                                    </ToolTip.Tip>
                                    <Panel>
                                        <TextBlock Text="{Binding IconGlyph}" FontSize="16" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   IsVisible="{Binding IconGlyph, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                        <TextBlock Text="{Binding Name}" FontSize="10" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="30"
                                                   IsVisible="{Binding IconGlyph, Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                                    </Panel>
                                </Border>
                                <!-- Facing-direction arrow (#70) - only sent by the Host for a
                                     Character-linked token (null otherwise), so IsVisible gates on
                                     that instead of needing the token's LinkKind over the wire. -->
                                <Path Data="M 0,-15 L 4,-8 L -4,-8 Z" Fill="White"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      IsVisible="{Binding FacingDegrees, Converter={x:Static ObjectConverters.IsNotNull}}"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform>
                                        <RotateTransform Angle="{Binding FacingDegrees}" />
                                    </Path.RenderTransform>
                                </Path>
                            </Panel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Ping ripples and annotation strokes render here, above tokens. A Canvas
                     (unlike ImageContentPanel's own default Panel arrangement) never repositions
                     its children based on their own bounding box - a Polyline placed directly in a
                     Stretch-arranged Panel gets shifted so ITS OWN geometry bounding box (which
                     includes stroke-thickness padding) aligns to the panel's origin, not the raw
                     image-space coordinates, which was the source of a slight but real rendering
                     offset. Canvas.Left/Top default to 0, so children here sit at literal
                     image-space (0,0) with no such shift. -->
                <Canvas x:Name="AnnotationOverlay" Width="{Binding CurrentFloorImageBitmap.PixelSize.Width}"
                        Height="{Binding CurrentFloorImageBitmap.PixelSize.Height}" IsHitTestVisible="False" />
                </Panel>
            </LayoutTransformControl>
        </ScrollViewer>

        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center"
                    VerticalAlignment="Bottom" Margin="0,0,0,16" IsVisible="{Binding HasMultipleFloors}">
            <Button Content="&#8249;" Command="{Binding PreviousFloorCommand}"
                    Background="#66000000" Foreground="White" BorderThickness="0" />
            <Border Background="#66000000" CornerRadius="6" Padding="10,6">
                <TextBlock Text="{Binding CurrentFloorName}" Foreground="White" />
            </Border>
            <Button Content="&#8250;" Command="{Binding NextFloorCommand}"
                    Background="#66000000" Foreground="White" BorderThickness="0" />
        </StackPanel>

        <!-- Zoom/pan toolbar - bottom-left specifically avoids every existing overlay in both
             host windows (game-time text top-left, minimize/close top-right, the floor-nav bar
             above is bottom-center, PlayerWindow's ExitFullscreenButton is bottom-right). Hidden
             when this view mirrors another control's viewport instead of owning its own zoom
             (see ShowZoomControls/SetExternalViewport) - the buttons would just get overridden by
             the next source-control zoom/pan anyway. -->
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left"
                    VerticalAlignment="Bottom" Margin="16"
                    IsVisible="{Binding #Self.ShowZoomControls}">
            <Button Content="&#8722;" Click="OnZoomOutClick"
                    Background="#66000000" Foreground="White" BorderThickness="0" />
            <Border Background="#66000000" CornerRadius="6" Padding="10,6">
                <TextBlock Name="ZoomLabel" Foreground="White" />
            </Border>
            <Button Content="&#43;" Click="OnZoomInClick"
                    Background="#66000000" Foreground="White" BorderThickness="0" />
            <Button Content="{DynamicResource MapDisplay.FitButton}" Click="OnZoomFitClick"
                    Background="#66000000" Foreground="White" BorderThickness="0" />
        </StackPanel>
    </Panel>
</UserControl>