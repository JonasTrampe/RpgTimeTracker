<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="using:RpgTimeTracker.Shared.ViewModels"
             x:Class="RpgTimeTracker.Shared.Views.PlayerHeaderView"
             x:DataType="viewModels:IPlayerDisplayContext">

    <Border Classes="chrome">
        <Grid ColumnDefinitions="*,Auto">
            <StackPanel Spacing="3">
                <TextBlock Classes="heroTitle" Text="{Binding PlayerHeaderTitle}" />
                <TextBlock Classes="muted" Text="{Binding PlayerHeaderSubtitle}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Right">
                <TextBlock Classes="muted" Text="{DynamicResource MainWindow.Clock.CurrentGameTime}"
                           HorizontalAlignment="Right" />
                <TextBlock Classes="clockValue" Text="{Binding CurrentGameTimeText}" HorizontalAlignment="Right" />
                <TextBlock Classes="muted" Text="{Binding SpeedLabel}"
                           HorizontalAlignment="Right" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>