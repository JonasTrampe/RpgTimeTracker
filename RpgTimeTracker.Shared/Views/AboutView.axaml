<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RpgTimeTracker.Shared.ViewModels"
             xmlns:mdxaml="clr-namespace:Markdown.Avalonia;assembly=Markdown.Avalonia"
             x:Class="RpgTimeTracker.Shared.Views.AboutView"
             x:DataType="vm:AboutViewModel">

    <ScrollViewer Margin="20">
        <StackPanel Spacing="14">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Classes="muted" Text="{DynamicResource About.VersionLabel}" />
                <TextBlock Classes="muted" Text="{Binding VersionText}" />
            </StackPanel>

            <mdxaml:MarkdownScrollViewer Markdown="{Binding ContentMarkdown}" />

            <Expander Header="{DynamicResource About.OwnLicenseHeader}">
                <mdxaml:MarkdownScrollViewer Markdown="{Binding LicenseText}" Margin="0,8,0,0" />
            </Expander>

            <Expander Header="{DynamicResource About.ThirdPartyHeader}">
                <mdxaml:MarkdownScrollViewer Markdown="{Binding ThirdPartyNoticesText}" Margin="0,8,0,0" />
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>