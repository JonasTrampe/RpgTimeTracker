<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:RpgTimeTracker.Shared.Views"
        x:Class="RpgTimeTracker.PlayerClient.Views.AboutWindow"
        Title="Über RPG Zeitverfolgung"
        Width="560" Height="640" MinWidth="420" MinHeight="360"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.Styles>
        <StyleInclude Source="avares://RpgTimeTracker.Shared/Styles/AppStyles.axaml" />
    </Window.Styles>

    <views:AboutView />
</Window>