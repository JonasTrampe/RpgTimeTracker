<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RpgTimeTracker.PlayerClient.ViewModels"
        xmlns:vlc="clr-namespace:LibVLCSharp.Avalonia;assembly=LibVLCSharp.Avalonia"
        x:Class="RpgTimeTracker.PlayerClient.Views.MediaWindow"
        x:DataType="vm:ClientMainWindowViewModel"
        Title="{Binding CurrentMediaFileName, StringFormat='Medium: {0}'}"
        Width="960" Height="600" MinWidth="320" MinHeight="240"
        Background="Black">
    <Panel PointerPressed="OnPanelPointerPressed"
           ToolTip.Tip="Klick: nächstes Bild/Video (Galerie) - Pfeiltasten funktionieren auch">
        <Image Source="{Binding CurrentMediaBitmap}" Stretch="Uniform" IsVisible="{Binding HasImageMedia}" />
        <vlc:VideoView MediaPlayer="{Binding MediaPlayer}" IsVisible="{Binding HasVideoMedia}" />

        <!-- Aktuelle Spielzeit bleibt sichtbar, auch wenn dieses eigenständige Fenster (oft
             fullscreen) die Zeitliste komplett verdeckt. -->
        <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12"
                Background="#66000000" CornerRadius="6" Padding="10,6">
            <TextBlock Text="{Binding CurrentGameTimeText}" Foreground="White" FontWeight="Bold" FontSize="14" />
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="12">
            <Button Click="OnMinimizeClick"
                    Content="&#8722;"
                    Width="28" Height="28"
                    CornerRadius="14"
                    Background="#66000000"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="16"
                    ToolTip.Tip="Fenster minimieren" />
            <Button Click="OnCloseClick"
                    Content="&#10005;"
                    Width="28" Height="28"
                    CornerRadius="14"
                    Background="#66000000"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="13"
                    ToolTip.Tip="Medium schließen" />
        </StackPanel>
    </Panel>
</Window>