<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RpgTimeTracker.PlayerClient.Views.ConfirmCleanupWindow"
        Title="RPG Zeitverfolgung"
        Width="420" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">
    <!--
        Einfacher Ja/Nein-Dialog fürs Aufräumen beim Schließen (siehe ClientMainWindow.OnClosing) -
        erster modaler Dialog in diesem Projekt, daher bewusst minimal statt eine allgemeine
        Dialog-Infrastruktur einzuführen, die sonst nirgends gebraucht wird.
    -->
    <Window.Styles>
        <StyleInclude Source="avares://RpgTimeTracker.Shared/Styles/AppStyles.axaml" />
    </Window.Styles>

    <Border Classes="card" Padding="20">
        <StackPanel Spacing="16">
            <TextBlock Classes="h2" Text="Temporäre Dateien löschen?" />
            <TextBlock TextWrapping="Wrap"
                       Text="Diese Sitzung hat vom Host empfangene Bilder/Videos lokal zwischengespeichert. Sollen diese Dateien jetzt gelöscht werden, bevor die App geschlossen wird?" />
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                <Button Content="Nicht löschen" Click="OnNoClick" />
                <Button Classes="primary" Content="Löschen" Click="OnYesClick" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>