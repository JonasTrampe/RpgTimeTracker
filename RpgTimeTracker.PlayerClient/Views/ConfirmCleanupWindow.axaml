<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RpgTimeTracker.PlayerClient.Views.ConfirmCleanupWindow"
        Title="RPG Zeitverfolgung"
        Width="420" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Styles>
        <StyleInclude Source="avares://RpgTimeTracker.Shared/Styles/AppStyles.axaml" />
    </Window.Styles>

    <Border Classes="card" Padding="20">
        <StackPanel Spacing="16">
            <TextBlock Classes="h2" Text="{DynamicResource ConfirmCleanup.Title}" />
            <TextBlock TextWrapping="Wrap"
                       Text="{DynamicResource ConfirmCleanup.Message}" />
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                <Button Content="{DynamicResource ConfirmCleanup.No}" Click="OnNoClick" />
                <Button Classes="primary" Content="{DynamicResource ConfirmCleanup.Yes}" Click="OnYesClick" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>